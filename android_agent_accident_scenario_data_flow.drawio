etry x="920" y="560" width="240" height="90" as="geometry"/></mxCell><mxCell id="13" value="TravelAdjustmentPlan" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1320" y="420" width="340" height="100" as="geometry"/></mxCell><mxCell id="14" value="SummaryCard" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1320" y="620" width="340" height="100" as="geometry"/></mxCell><mxCell id="15" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="24" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="26" value="体验保全原则&lt;br&gt;这时系统的目标不是“重新设计旅行”，而是“尽量少动原计划，只把事故造成的缺口补上”。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="820" width="1620" height="100" as="geometry"/></mxCell><mxCell id="27" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="29" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="31" value="说明行程、住宿、餐饮三条体验链如何读取同一批事故后事实，并合成 TravelAdjustmentPlan。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="33" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="35" value="repair_eta、service_center、rental_booking、原 14 天行程、用户偏好。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="37" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="39" value="TravelAdjustmentPlan 和可呈现给用户的 SummaryCard。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="41" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="43" value="1. 后续安排输入 -&gt; Trip/Lodging/Dining Agent | 维修 ETA、位置、偏好、原计划 | 三个 agent 获得同一批事实&lt;br&gt;2. TripAgent -&gt; Map / weather connector | 原线路和新的时间窗口 | 黄石整体后移 2 天&lt;br&gt;3. LodgingAgent -&gt; Hotel connector | 今晚落脚城市、评分、距离、宠物偏好 | Marriott Billings&lt;br&gt;4. DiningAgent -&gt; Restaurant connector | 酒店位置、步行距离、放松型偏好 | Walker's Grill 19:00&lt;br&gt;5. 三条结果 -&gt; TravelAdjustmentPlan | 行程、酒店、餐饮结果 | TravelAdjustmentPlan" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="45" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="47" value="TripAgent | 负责最小改动地平移旅行计划 | 入:原计划、维修 ETA、路况天气 | 出:新行程 | 例:黄石主体验保留&lt;br&gt;LodgingAgent | 负责今晚和次日的落脚点 | 入:服务中心位置、用户偏好 | 出:酒店预订结果 | 例:离 Tesla 服务点 1.8 英里&lt;br&gt;DiningAgent | 负责事故后的用餐安排 | 入:酒店位置、步行距离、口味偏好 | 出:餐饮预订结果 | 例:19:00 晚餐&lt;br&gt;TravelAdjustmentPlan | 统一承载所有改动后的旅行安排 | 入:三个 agent 输出 | 出:新旅行计划 | 例:Day 3~4 平移&lt;br&gt;SummaryCard | 把体验安排和事故状态一屏展示 | 入:旅行结果 + 理赔/维修状态 | 出:通知卡片 | 例:今晚酒店+晚餐+明日取车" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="136" as="geometry"/></mxCell><mxCell id="49" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="900" width="860" height="28" as="geometry"/></mxCell><mxCell id="51" value="输入例子: repair_eta='1~3 days', prefs={pet:true, hotel_rating&gt;4.2}&lt;br&gt;输出例子: TravelAdjustmentPlan.days_shifted=2, hotel='Marriott Billings', dinner='Walker's Grill'" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="934" width="860" height="76" as="geometry"/></mxCell><mxCell id="53" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1022" width="860" height="28" as="geometry"/></mxCell><mxCell id="55" value="已有: TaskContext/Recipe 可表达部分固定模板&lt;br&gt;stub: 无真正 travel/hotel/restaurant connector&lt;br&gt;目标态: TravelAdjustmentPlan、SummaryCard 收口、长任务持续刷新" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1056" width="860" height="96" as="geometry"/></mxCell><mxCell id="57" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1164" width="860" height="28" as="geometry"/></mxCell><mxCell id="59" value="如果不把维修 ETA 和理赔覆盖纳入输入，系统可能会给出表面好看但实际无法执行的行程安排。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1198" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="17-t+1~2-天恢复流" name="17 T+1~2 天恢复流"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="17 T+1~2 天恢复流" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="跨天恢复是整套场景最容易被低估的一段，必须显式依赖 durable store 和 scheduler。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="前一日输出
