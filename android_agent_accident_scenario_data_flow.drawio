n=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="38" value="明确哪些能力不是多写几个 App 代码就能解决，而是需要系统或 OEM 协同。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="40" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="42" value="事故场景目标能力清单。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="44" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="46" value="一组系统级 / OEM 需求，以及不补齐时的直接后果。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="48" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="50" value="1. 目标能力清单 -&gt; 三方 App 能力评估 | 想要实现的事故能力 | 识别能力缺口&lt;br&gt;2. 能力缺口 -&gt; OEM / system 需求 | 缺口项 | 形成能力请求单&lt;br&gt;3. OEM / system 需求 -&gt; 落地影响 | 需求未满足情况 | 形成清晰边界" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="96" as="geometry"/></mxCell><mxCell id="52" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="678" width="860" height="28" as="geometry"/></mxCell><mxCell id="54" value="三方 App 能力 | 当前普通应用大致能做到的范围 | 入:Android 标准权限和服务 | 出:有限能力 | 例:通知读取、联系人搜索&lt;br&gt;OEM / system 能力 | 厂商或系统才能稳定提供的能力 | 入:系统服务或预装身份 | 出:关键闭环能力 | 例:锁屏 UI、强保活&lt;br&gt;事故能力缺口 | 场景目标和现状之间的差距 | 入:目标能力与现有能力对比 | 出:需求列表 | 例:车端实时 feed" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="712" width="860" height="96" as="geometry"/></mxCell><mxCell id="56" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="820" width="860" height="28" as="geometry"/></mxCell><mxCell id="58" value="输入例子: 能力='锁屏红色紧急卡片+长时保活'&lt;br&gt;输出例子: 需求='系统级锁屏 UI + 保活，不然只能退化成高优先通知'" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="854" width="860" height="76" as="geometry"/></mxCell><mxCell id="60" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="942" width="860" height="28" as="geometry"/></mxCell><mxCell id="62" value="已有: 普通 App 现有能力有限&lt;br&gt;stub: 可用 Accessibility/ForegroundService 勉强接近部分能力&lt;br&gt;目标态: 真正稳定的事故闭环需要系统级支持" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="976" width="860" height="96" as="geometry"/></mxCell><mxCell id="64" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1084" width="860" height="28" as="geometry"/></mxCell><mxCell id="66" value="如果把系统级需求藏起来，整套设计会在实际产品推进时突然撞墙。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1118" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="25-实施路线与优先级" name="25 实施路线与优先级"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="25 实施路线与优先级" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把事故场景从图纸落到执行路线：先补哪一层，后补哪一层，为什么。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="Phase 0
先把图和对象讲清楚" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="100" y="240" width="280" height="96" as="geometry"/></mxCell><mxCell id="8" value="统一 CrashSnapshot / IncidentContext / RepairPlan / SummaryCard 等对象名，避免后续实现时字段漂移。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="440" y="240" width="1160" height="96" as="geometry"/></mxCell><mxCell id="9" value="Phase 1
做手动触发的事故 MVP" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="100" y="410" width="280" height="96" as="geometry"/></mxCell><mxCell id="11" value="先从 Manual SOS、单 orchestrator、最小紧急链、TaskLog 和审批开始。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="440" y="410" width="1160" height="96" as="geometry"/></mxCell><mxCell id="12" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="13" value="Phase 2
补连接器与证据链" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="100" y="580" width="280" height="96" as="geometry"/></mxCell><mxCell id="15" value="补 location、sms、media、Insurance/AAA/Tesla Service 基础 connector，并形成 EvidenceBundle。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="440" y="580" width="1160" height="96" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" value="Phase 3
补长任务恢复" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="100" y="750" width="280" height="96" as="geometry"/></mxCell><mxCell id="19" value="增加 Durable Incident Store、Durable Approval Store、Recovery Scheduler。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="440" y="750" width="1160" height="96" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="17" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" value="Phase 4
再考虑多 Agent 与 OEM 深化" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="100" y="920" width="280" height="96" as="geometry"/></mxCell><mxCell id="23" value="等主链稳定后再上 IncidentCoordinator、事件总线、系统级入口。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="440" y="920" width="1160" height="96" as="geometry"/></mxCell><mxCell id="24" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="17" target="21" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="25" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="27" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="29" value="把整套设计按可落地顺序排出来，告诉读者应该先补哪一层，不该一开始就追求完美。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="31" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="33" value="当前仓库骨架、事故场景目标态、差距清单。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="35" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="37" value="分阶段实施路线，以及每一阶段的重点目标。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="39" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="41" value="1. 当前骨架和差距清单 -&gt; 路线排序 | 已有能力、stub、缺失项 | 得到阶段路线&lt;br&gt;2. 路线排序 -&gt; Phase 1~4 | 阶段目标 | 形成分期计划&lt;br&gt;3. 每个阶段 -&gt; 下一阶段输入 | 上一阶段稳定输出 | 逐层推进" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="96" as="geometry"/></mxCell><mxCell id="43" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="678" width="860" height="28" as="geometry"/></mxCell><mxCell id="45" value="Phase 1 | 最小可用事故闭环 | 入:Manual SOS、单 orchestrator、审批、日志 | 出:最早可演示版本 | 例:先能人工触发事故流程&lt;br&gt;Phase 2 | 把外联和证据链接上 | 入:基础 connector 和证据采集 | 出:更像真实产品的中间版本 | 例:能拿到 claim draft&lt;br&gt;Phase 3 | 让系统跨天不丢 | 入:durable store 和 scheduler | 出:可持续长任务 | 例:第二天还能继续&lt;br&gt;Phase 4 | 增强智能和系统深度 | 入:多 Agent 和 OEM 能力 | 出:更完整的系统级 agent | 例:更接近最终目标" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="712" width="860" height="116" as="geometry"/></mxCell><mxCell id="47" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="840" width="860" height="28" as="geometry"/></mxCell><mxCell id="49" value="输入例子: 当前只有 MvpRuntime + AgentOrchestrator + TaskLog + Approval&lt;br&gt;输出例子: 优先先做 Manual SOS MVP，而不是先做 6 个 Agent 并行" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="874" width="860" height="76" as="geometry"/></mxCell><mxCell id="51" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="962" width="860" height="28" as="geometry"/></mxCell><mxCell id="53" value="已有: 当前最适合直接起步的是手动事故 MVP&lt;br&gt;stub: 很多中高风险工具还是 stub&lt;br&gt;目标态: 长任务恢复和 OEM 深化需要分阶段推进" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="996" width="860" height="96" as="geometry"/></mxCell><mxCell id="55" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1104" width="860" height="28" as="geometry"/></mxCell><mxCell id="57" value="如果一上来就做 Tesla feed、多 Agent、OEM 级入口，项目会被过多依赖拖住，反而拿不到最小闭环。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1138" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>