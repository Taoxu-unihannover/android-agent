<mxfile host="app.diagrams.net" modified="2026-03-14T04:35:08Z" agent="Codex" version="24.7.17"><diagram id="01-阅读导航" name="01 阅读导航"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="01 阅读导航" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="先看全貌，再沿着时间轴拆开触发、即时响应、跨天恢复和工程边界。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="先建立全局认识" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="70" y="200" width="320" height="66" as="geometry"/></mxCell><mxCell id="8" value="02 总图&lt;br&gt;03 名词表与颜色图例&lt;br&gt;04 合理性与实现前提" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="70" y="290" width="320" height="360" as="geometry"/></mxCell><mxCell id="9" value="再理解事故入口" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="470" y="200" width="320" height="66" as="geometry"/></mxCell><mxCell id="11" value="05 触发与紧急模式总览&lt;br&gt;06 触发流详细步骤&lt;br&gt;07 无 Tesla feed 的降级流" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="470" y="290" width="320" height="360" as="geometry"/></mxCell><mxCell id="12" value="再读事故主流程" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="870" y="200" width="320" height="66" as="geometry"/></mxCell><mxCell id="14" value="08 主控工作流与并行子任务&lt;br&gt;09 T+0~3 分钟总览&lt;br&gt;10~17 各阶段拆图" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="870" y="290" width="320" height="360" as="geometry"/></mxCell><mxCell id="15" value="最后看工程边界" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1270" y="200" width="320" height="66" as="geometry"/></mxCell><mxCell id="17" value="18 证据与审计流&lt;br&gt;19~25 风险、恢复、当前实现、OEM 需求和路线图" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1270" y="290" width="320" height="360" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="15" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" value="推荐阅读顺序" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=18;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="700" width="220" height="28" as="geometry"/></mxCell><mxCell id="23" value="1. 先看 02 总图，知道大框架。&lt;br&gt;2. 再看 05~08，理解事故怎么进入系统以及主控如何组织任务。&lt;br&gt;3. 再看 09~17，按时间轴理解数据如何流动。&lt;br&gt;4. 最后看 18~25，理解证据、审批、恢复、OEM 依赖和实施路线。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="740" width="1590" height="150" as="geometry"/></mxCell><mxCell id="24" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="26" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="28" value="告诉第一次阅读这套图的人，应该按什么顺序看，才不会被大量组件名和场景细节淹没。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="30" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="32" value="文件名、页名、颜色含义、事故场景的时间轴。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="34" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="36" value="一条可执行的阅读路线：总图 -&gt; 入口 -&gt; 前 20 分钟 -&gt; 后续安排 -&gt; 工程边界。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="38" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="40" value="1. 读者 -&gt; 阅读导航 | 页名与阶段顺序 | 形成阅读顺序&lt;br&gt;2. 阅读导航 -&gt; 02 总图 | 系统全貌 | 建立大局观&lt;br&gt;3. 02 总图 -&gt; 05~17 各阶段页 | 某一阶段的细节 | 理解每一跳经过的组件&lt;br&gt;4. 05~17 各阶段页 -&gt; 18~25 工程边界页 | 证据、审批、恢复、OEM 依赖 | 读懂现实边界" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="116" as="geometry"/></mxCell><mxCell id="42" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="698" width="860" height="28" as="geometry"/></mxCell><mxCell id="44" value="阅读导航 | 把 25 页按阅读顺序分组 | 入:页名 | 出:推荐阅读路线 | 例:先看 02，再看 05~07&lt;br&gt;总图 | 把所有组件先放在一张图上 | 入:事故场景 | 出:全链路框架 | 例:从 CrashSnapshot 走到 SummaryCard&lt;br&gt;拆解页 | 把总图中的一部分单独展开 | 入:某一阶段或某一层 | 出:详细数据流 | 例:把 911 呼叫链单独拆成一页&lt;br&gt;工程边界页 | 说明哪里是当前已有、哪里是 stub、哪里要 OEM | 入:当前代码和目标场景 | 出:现实可行性判断 | 例:AgentForegroundService 现在还是空壳" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="732" width="860" height="116" as="geometry"/></mxCell><mxCell id="46" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="860" width="860" height="28" as="geometry"/></mxCell><mxCell id="48" value="输入例子: 页名=10 紧急响应链详细流&lt;br&gt;输出例子: 你能回答“拨 911 前先经过 RiskPolicy 和 Approval”" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="894" width="860" height="76" as="geometry"/></mxCell><mxCell id="50" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="982" width="860" height="28" as="geometry"/></mxCell><mxCell id="52" value="已有: 图册生成和分页结构&lt;br&gt;stub: 无&lt;br&gt;目标态: 让完全不懂的人也能按阶段读懂" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1016" width="860" height="96" as="geometry"/></mxCell><mxCell id="54" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1124" width="860" height="28" as="geometry"/></mxCell><mxCell id="56" value="最容易误解的是直接跳到某一页看细节，结果不知道它在全局里处于哪个阶段。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1158" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="02-总图" name="02 总图"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="02 总图" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="用一张图把事故从触发到恢复的整条数据流串起来，再逐步拆开。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="事故触发
