9AM 取车 -&gt; 10AM 维修 -&gt; 行程继续" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1400" y="260" width="340" height="110" as="geometry"/></mxCell><mxCell id="12" value="更新后的 SummaryCard" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1400" y="500" width="340" height="100" as="geometry"/></mxCell><mxCell id="13" value="当前缺口
ForegroundService 空壳 + 全部内存态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#ef4444;fillColor=#fee2e2;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1020" y="560" width="260" height="100" as="geometry"/></mxCell><mxCell id="14" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="15" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#ef4444;dashed=1;" parent="1" source="13" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" value="这页一定要读懂&lt;br&gt;因为很多“看起来很智能”的 demo 都会在跨夜之后断掉。&lt;br&gt;真正产品化时，恢复逻辑往往比单次工具调用更重要。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#ef4444;fillColor=#fee2e2;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="820" width="1680" height="110" as="geometry"/></mxCell><mxCell id="24" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="26" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="28" value="解释为什么跨天恢复不能只靠内存态 TaskLog 和前台页面，必须有 durable state 和恢复调度。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="30" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="32" value="前一日留下的 claim_id、RepairPlan、TravelAdjustmentPlan、未决审批和提醒时间。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="34" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="36" value="第二天仍然正确执行的恢复动作，以及更新后的 SummaryCard。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="38" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="40" value="1. 前一日输出 -&gt; Durable Incident / Approval Store | 事故状态和待决审批 | 持久化状态存在&lt;br&gt;2. Durable Store -&gt; Recovery Scheduler / Watchdog | 恢复时间点和状态 | 恢复任务被调度&lt;br&gt;3. Scheduler -&gt; Recovery Service | 恢复任务 | 恢复服务启动&lt;br&gt;4. Recovery Service -&gt; 恢复动作 | 租车、维修、旅程后移等待执行事项 | 9AM/10AM 动作继续&lt;br&gt;5. 恢复动作 -&gt; SummaryCard | 最新状态 | 用户看到新的今日安排" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="42" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="44" value="Durable Incident Store | 跨天保存事故主状态 | 入:IncidentContext、子任务状态 | 出:可恢复状态 | 例:手机重启后还能知道事故没结束&lt;br&gt;Durable Approval Store | 跨天保存待审批动作 | 入:PendingApproval | 出:待恢复审批队列 | 例:昨天没点的酒店付款今天还在&lt;br&gt;Recovery Scheduler | 负责定时拉起恢复流程 | 入:时间点、未完成状态 | 出:恢复任务 | 例:8:50 提醒即将取车&lt;br&gt;Recovery Service | 实际执行恢复逻辑的宿主 | 入:恢复任务 | 出:新的结果和通知 | 例:更新 SummaryCard" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="116" as="geometry"/></mxCell><mxCell id="46" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="880" width="860" height="28" as="geometry"/></mxCell><mxCell id="48" value="输入例子: repair_checkin='2026-03-15 10:00', rental_pickup='2026-03-15 09:00'&lt;br&gt;输出例子: summary.today='9AM 取车, 10AM Tesla Service, claim ongoing'" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="914" width="860" height="76" as="geometry"/></mxCell><mxCell id="50" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1002" width="860" height="28" as="geometry"/></mxCell><mxCell id="52" value="已有: TaskLog 和 ApprovalStore 目前都是内存态抽象&lt;br&gt;stub: ForegroundService 只有最小 Service 壳&lt;br&gt;目标态: durable incident state、durable approval、watchdog 恢复服务" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1036" width="860" height="96" as="geometry"/></mxCell><mxCell id="54" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1144" width="860" height="28" as="geometry"/></mxCell><mxCell id="56" value="最容易误解的是认为“昨天已经安排过一次”就自然会延续到今天。手机系统不会替你记住这些业务状态。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1178" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="18-证据与审计流" name="18 证据与审计流"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="18 证据与审计流" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把“发生了什么、做过什么、谁批准的”沉成可追溯的证据链。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="手机证据采集
照片/录屏/截图" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="240" width="280" height="100" as="geometry"/></mxCell><mxCell id="7" value="车端证据流
Tesla media export" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="430" width="280" height="100" as="geometry"/></mxCell><mxCell id="8" value="TaskLogRepository" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="450" y="180" width="260" height="90" as="geometry"/></mxCell><mxCell id="9" value="Observation stream" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="450" y="340" width="260" height="90" as="geometry"/></mxCell><mxCell id="10" value="Approval records" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="450" y="500" width="260" height="90" as="geometry"/></mxCell><mxCell id="11" value="EvidenceBundle" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="830" y="260" width="300" height="96" as="geometry"/></mxCell><mxCell id="12" value="IncidentTimeline" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="830" y="470" width="300" height="96" as="geometry"/></mxCell><mxCell id="13" value="审计导出 / 理赔附件" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1250" y="360" width="340" height="100" as="geometry"/></mxCell><mxCell id="14" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="15" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" value="证据链原则&lt;br&gt;动作日志、审批记录和媒体证据必须能互相对上时间。&lt;br&gt;否则出了问题只能看到“做了什么”，却说不清“为什么做、谁同意的”。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="780" width="1540" height="110" as="geometry"/></mxCell><mxCell id="23" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="25" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="27" value="说明事故处理不是只有业务结果，还必须形成可追溯的证据链和审计链。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="29" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="31" value="媒体证据、TaskLog、Observation、审批记录。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="33" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="35" value="EvidenceBundle、IncidentTimeline，以及可导出的审计材料。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="37" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="39" value="1. 手机证据采集 / 车端证据流 -&gt; EvidenceBundle | 照片、录屏、车端媒体 | EvidenceBundle&lt;br&gt;2. TaskLogRepository -&gt; IncidentTimeline | 动作日志 | 时间线事件&lt;br&gt;3. Observation stream -&gt; IncidentTimeline | 工具观测结果 | 时间线事实&lt;br&gt;4. Approval records -&gt; IncidentTimeline | 谁批准了什么 | 审批事件&lt;br&gt;5. EvidenceBundle + IncidentTimeline -&gt; 审计导出 / 理赔附件 | 证据包和时间线 | 理赔附件或审计包" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="41" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="43" value="TaskLogRepository | 记录执行日志 | 入:TaskLogEvent | 出:任务日志列表 | 例:tool.result&lt;br&gt;Observation stream | 记录工具看到的新事实 | 入:ToolResult.observations | 出:Observation 列表 | 例:notifications.list&lt;br&gt;Approval records | 记录风险动作审批 | 入:PendingApproval / decision | 出:审批历史 | 例:ALLOW_ONCE&lt;br&gt;EvidenceBundle | 收纳所有证据引用 | 入:手机和车端证据 | 出:bundle id | 例:claim-prep-01&lt;br&gt;IncidentTimeline | 按时间整合动作、事实和审批 | 入:日志、观测、审批 | 出:全局时间线 | 例:14:34 crash -&gt; 14:37 911" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="136" as="geometry"/></mxCell><mxCell id="45" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="900" width="860" height="28" as="geometry"/></mxCell><mxCell id="47" value="输入例子: photo://plate-1 + tasklog(tool.result) + approval(send_sms)&lt;br&gt;输出例子: audit_export.zip / claim_attachment_bundle" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="934" width="860" height="76" as="geometry"/></mxCell><mxCell id="49" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1022" width="860" height="28" as="geometry"/></mxCell><mxCell id="51" value="已有: TaskLog、Observation 抽象&lt;br&gt;stub: 审批持久化仍薄弱&lt;br&gt;目标态: 车端证据流、审计导出、完整证据包" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1056" width="860" height="96" as="geometry"/></mxCell><mxCell id="53" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1164" width="860" height="28" as="geometry"/></mxCell><mxCell id="55" value="很多人只看业务结果，不看证据链；但事故场景如果没有证据链，后面理赔、争议和复盘都会出问题。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1198" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="19-审批与风险边界流" name="19 审批与风险边界流"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="19 审批与风险边界流" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把 L0/L1/L2/L3 风险等级、自动化边界和审批超时后的处理讲清楚。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="风险级别" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="60" y="180" width="120" height="54" as="geometry"/></mxCell><mxCell id="7" value="动作类型" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="200" y="180" width="220" height="54" as="geometry"/></mxCell><mxCell id="8" value="默认处理" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="440" y="180" width="320" height="54" as="geometry"/></mxCell><mxCell id="9" value="事故场景例子" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="780" y="180" width="380" height="54" as="geometry"/></mxCell><mxCell id="10" value="结果" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1180" y="180" width="420" height="54" as="geometry"/></mxCell><mxCell id="11" value="L0" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="254" width="120" height="120" as="geometry"/></mxCell><mxCell id="12" value="只读观察" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="200" y="254" width="220" height="120" as="geometry"/></mxCell><mxCell id="13" value="直接自动执行" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="440" y="254" width="320" height="120" as="geometry"/></mxCell><mxCell id="14" value="device.status、notifications.list、contacts.search" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="780" y="254" width="380" height="120" as="geometry"/></mxCell><mxCell id="15" value="不需要审批，直接写 Observation。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1180" y="254" width="420" height="120" as="geometry"/></mxCell><mxCell id="16" value="L1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="392" width="120" height="120" as="geometry"/></mxCell><mxCell id="17" value="低风险变更" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="200" y="392" width="220" height="120" as="geometry"/></mxCell><mxCell id="18" value="通常可自动执行，但要记日志" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="440" y="392" width="320" height="120" as="geometry"/></mxCell><mxCell id="19" value="calendar.add、app.launch" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="780" y="392" width="380" height="120" as="geometry"/></mxCell><mxCell id="20" value="默认允许，失败可重试。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1180" y="392" width="420" height="120" as="geometry"/></mxCell><mxCell id="21" value="L2" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="530" width="120" height="120" as="geometry"/></mxCell><mxCell id="22" value="中风险动作" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="200" y="530" width="220" height="120" as="geometry"/></mxCell><mxCell id="23" value="必须明确确认或受更强策略控制" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="440" y="530" width="320" height="120" as="geometry"/></mxCell><mxCell id="24" value="sms.send、camera.snap、screen.capture、share location" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="780" y="530" width="380" height="120" as="geometry"/></mxCell><mxCell id="25" value="创建 PendingApproval；超时不得悄悄继续。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1180" y="530" width="420" height="120" as="geometry"/></mxCell><mxCell id="26" value="L3" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="668" width="120" height="120" as="geometry"/></mxCell><mxCell id="27" value="高风险动作" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="200" y="668" width="220" height="120" as="geometry"/></mxCell><mxCell id="28" value="MVP 默认禁止或只允许系统级例外策略" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="440" y="668" width="320" height="120" as="geometry"/></mxCell><mxCell id="29" value="完全自动拨 911、代替用户完成高影响操作" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="780" y="668" width="380" height="120" as="geometry"/></mxCell><mxCell id="30" value="默认 block，除非系统级 emergency policy 明确放行。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1180" y="668" width="420" height="120" as="geometry"/></mxCell><mxCell id="31" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="33" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="35" value="说明事故场景并不意味着可以跳过风险控制，相反，越紧急越要明确自动化边界。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="37" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="39" value="一个待执行动作及其 ToolDefinition.riskLevel。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="41" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="43" value="允许执行、等待审批、超时挂起或明确阻塞。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="45" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="47" value="1. 待执行动作 -&gt; RiskPolicyEngine | toolName、riskLevel、requiresConfirmation | 得到 PolicyDecision&lt;br&gt;2. RiskPolicyEngine -&gt; ApprovalCoordinator | 需要确认的动作 | 等待用户决定&lt;br&gt;3. 用户 / 系统审批服务 -&gt; ApprovalCoordinator | ALLOW_ONCE / DENY / TIMEOUT | 审批状态确定&lt;br&gt;4. 审批结果 -&gt; 执行链或挂起链 | 批准/拒绝/超时 | 动作完成或挂起" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="116" as="geometry"/></mxCell><mxCell id="49" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="698" width="860" height="28" as="geometry"/></mxCell><mxCell id="51" value="RiskPolicyEngine | 根据风险等级评估动作 | 入:ToolDefinition | 出:PolicyDecision | 例:L2 需要审批&lt;br&gt;ApprovalCoordinator | 管理待审批动作 | 入:请求和结果 | 出:PendingApproval / resolved approval | 例:短信发送审批&lt;br&gt;PendingApproval | 事故处理中等待用户决定的动作 | 入:toolName、summary、ttl | 出:待处理状态 | 例:share location to Sarah&lt;br&gt;系统级 emergency policy | 目标态下对极少数动作提供例外策略 | 入:明确规则 | 出:更严格的自动化边界 | 例:仅系统级 911 例外" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="732" width="860" height="116" as="geometry"/></mxCell><mxCell id="53" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="860" width="860" height="28" as="geometry"/></mxCell><mxCell id="55" value="输入例子: tool=sms.send, risk=L2&lt;br&gt;输出例子: PendingApproval{summary='是否向 Sarah 发送事故短信?'}" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="894" width="860" height="76" as="geometry"/></mxCell><mxCell id="57" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="982" width="860" height="28" as="geometry"/></mxCell><mxCell id="59" value="已有: RiskPolicyEngine、ApprovalCoordinator、InMemoryApprovalStore&lt;br&gt;stub: 审批结果仍是内存态，不耐重启&lt;br&gt;目标态: 系统级审批面板、durable approval、紧急例外策略" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1016" width="860" height="96" as="geometry"/></mxCell><mxCell id="61" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1124" width="860" height="28" as="geometry"/></mxCell><mxCell id="63" value="最危险的误解是“事故紧急，所以系统可以绕过所有审批”。这会直接破坏用户信任和合规性。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1158" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="20-agent-间依赖与共享事件总线" name="20 Agent 间依赖与共享事件总线"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="20 Agent 间依赖与共享事件总线" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="用共享事件而不是硬编码互相调用，才能让多个子任务并行又不乱。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="IncidentCoordinator" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="720" y="120" width="300" height="92" as="geometry"/></mxCell><mxCell id="7" value="Shared Incident Event Bus" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="720" y="