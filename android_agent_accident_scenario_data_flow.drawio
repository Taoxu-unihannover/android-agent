ize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="12" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="32" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="33" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="15" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="34" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="16" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="35" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="17" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="36" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="18" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="37" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="19" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="39" value="事件总线的价值&lt;br&gt;TripAgent 不需要直接调用 TowRepairAgent。&lt;br&gt;它只需要订阅 repair_eta 这个事件，就知道何时可以调整黄石行程。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="1020" width="1620" height="100" as="geometry"/></mxCell><mxCell id="40" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="42" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="44" value="说明多子任务并行时，正确的耦合方式是共享事件，而不是互相直接调用。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="46" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="48" value="IncidentCoordinator 分发的子任务和事件总线。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="50" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="52" value="被多个子任务消费和生产的共享事件集合。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="54" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="56" value="1. IncidentCoordinator -&gt; 事件总线 | 任务计划和初始事实 | 事件总线开始有内容&lt;br&gt;2. 事件总线 -&gt; 各专项 Agent | incident.confirmed 等基础事实 | 并行启动&lt;br&gt;3. 各专项 Agent -&gt; 事件总线 | police_case_id、claim_id、repair_eta、lodging_selected | 共享事实越来越完整&lt;br&gt;4. 后续 Agent -&gt; 事件总线 | 已产生的共享事实 | 行程/住宿/餐饮互相协同但不硬连" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="116" as="geometry"/></mxCell><mxCell id="58" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="698" width="860" height="28" as="geometry"/></mxCell><mxCell id="60" value="Shared Incident Event Bus | 统一分发和存储共享事实 | 入:事件 | 出:可订阅的事件流 | 例:repair_eta 被多个 agent 用到&lt;br&gt;IncidentCoordinator | 决定起哪些子任务 | 入:IncidentContext | 出:子任务 + 初始事件 | 例:incident.confirmed&lt;br&gt;专项 Agent | 消费和生产事件 | 入:自己需要的共享事实 | 出:新的共享事实 | 例:InsuranceAgent 产出 claim_id&lt;br&gt;共享事件 | 跨子任务的最小依赖单位 | 入:业务结果 | 出:统一字段 | 例:lodging_selected" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="732" width="860" height="116" as="geometry"/></mxCell><mxCell id="62" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="860" width="860" height="28" as="geometry"/></mxCell><mxCell id="64" value="输入例子: event='repair_eta:1~3 days'&lt;br&gt;输出例子: TripAgent 读取后生成 days_shifted=2 的新行程" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="894" width="860" height="76" as="geometry"/></mxCell><mxCell id="66" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="982" width="860" height="28" as="geometry"/></mxCell><mxCell id="68" value="已有: TaskContext + Observation + TaskLog 可近似做部分共享事实&lt;br&gt;stub: 没有独立事件总线&lt;br&gt;目标态: 真正的 incident event bus 与订阅机制" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1016" width="860" height="96" as="geometry"/></mxCell><mxCell id="70" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1124" width="860" height="28" as="geometry"/></mxCell><mxCell id="72" value="如果让 Agent 之间直接互相调用，后期会出现难以维护的链式依赖和循环等待。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1158" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="21-状态机与长任务恢复" name="21 状态机与长任务恢复"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="21 状态机与长任务恢复" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把事故看成显式状态机，才能解释它当前卡在哪一段、下一步还能不能继续。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="DETECTED" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="100" y="260" width="180" height="72" as="geometry"/></mxCell><mxCell id="7" value="USER_STATUS_PENDING" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="330" y="260" width="220" height="72" as="geometry"/></mxCell><mxCell id="8" value="EMERGENCY_ACTIVE" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="610" y="260" width="200" height="72" as="geometry"/></mxCell><mxCell id="9" value="SAFETY_STABILIZED" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="870" y="260" width="220" height="72" as="geometry"/></mxCell><mxCell id="10" value="CLAIM_IN_PROGRESS" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1150" y="260" width="220" height="72" as="geometry"/></mxCell><mxCell id="11" value="REPAIR_LOGISTICS_SET" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1430" y="260" width="250" height="72" as="geometry"/></mxCell><mxCell id="12" value="TRAVEL_REPLANNED" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="540" y="520" width="220" height="72" as="geometry"/></mxCell><mxCell id="13" value="RECOVERING" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="900" y="520" width="180" height="72" as="geometry"/></mxCell><mxCell id="14" value="COMPLETED" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1220" y="520" width="180" height="72" as="geometry"/></mxCell><mxCell id="15" value="Durable Incident Store / Approval Store / Scheduler" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="650" y="760" width="580" height="100" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="24" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="8" target="15" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="25" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="10" target="15" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="26" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="12" target="15" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="27" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="13" target="15" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="29" value="状态机的意义&lt;br&gt;不是为了画得漂亮，而是为了明确：当前在哪个阶段、哪些事件能触发迁移、哪些失败会回退或挂起。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="980" width="1640" height="90" as="geometry"/></mxCell><mxCell id="30" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="32" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="34" value="解释为什么事故流程必须有显式状态机，而不是一串零散 API 调用。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="36" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="38" value="事故初始检测事件和当前 incident state。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="40" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="42" value="明确的状态迁移、可恢复点和最终完成状态。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="44" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="46" value="1. 事故检测 -&gt; DETECTED | CrashSnapshot | 进入首个状态&lt;br&gt;2. 用户确认和安全处理 -&gt; EMERGENCY_ACTIVE / SAFETY_STABILIZED | 用户状态、911 处理结果 | 安全状态更新&lt;br&gt;3. 理赔和维修推进 -&gt; CLAIM_IN_PROGRESS / REPAIR_LOGISTICS_SET | claim_id、repair_eta | 中间状态可跟踪&lt;br&gt;4. 旅行调整和跨天恢复 -&gt; TRAVEL_REPLANNED / RECOVERING | TravelAdjustmentPlan、提醒时间点 | 可以跨天继续&lt;br&gt;5. 恢复完成 -&gt; COMPLETED | 所有子任务收口 | SummaryCard 标记完成" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="48" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="50" value="状态机 | 定义 incident 允许处于哪些状态 | 入:当前事实 | 出:新的 incident state | 例:CLAIM_IN_PROGRESS&lt;br&gt;状态迁移 | 定义什么时候从一个状态到下一个状态 | 入:事件和条件 | 出:新状态 | 例:收到 police_case_id&lt;br&gt;Durable Stores | 保证状态迁移不会因为进程消失而丢失 | 入:incident state、审批、提醒 | 出:持久化状态 | 例:第二天还能恢复&lt;br&gt;Scheduler | 在需要时触发恢复迁移 | 入:时间事件 | 出:恢复动作 | 例:早上 8:50 拉起提醒" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="116" as="geometry"/></mxCell><mxCell id="52" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="880" width="860" height="28" as="geometry"/></mxCell><mxCell id="54" value="输入例子: current_state='CLAIM_IN_PROGRESS', event='repair_eta_received'&lt;br&gt;输出例子: next_state='REPAIR_LOGISTICS_SET'" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="914" width="860" height="76" as="geometry"/></mxCell><mxCell id="56" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1002" width="860" height="28" as="geometry"/></mxCell><mxCell id="58" value="已有: TaskStatus 等枚举已经存在，但不是 incident 级状态机&lt;br&gt;stub: 当前没有 durable 迁移存储&lt;br&gt;目标态: 完整 incident state machine + 持久恢复" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1036" width="860" height="96" as="geometry"/></mxCell><mxCell id="60" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1144" width="860" height="28" as="geometry"/></mxCell><mxCell id="62" value="没有状态机时，系统只能靠日志猜当前卡在哪，几乎无法可靠恢复。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1178" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="22-失败回退与降级路径" name="22 失败回退与降级路径"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="22 失败回退与降级路径" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把 5 类最关键失败流画出来，说明系统如何退化而不是直接崩掉。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="失败类型" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="60" y="180" width="250" height="54" as="geometry"/></mxCell><mxCell id="7" value="回退入口" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="330" y="180" width="280" height="54" as="geometry"/></mxCell><mxCell id="8" value="降级后的数据流" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="630" y="180" width="520" height="54" as="geometry"/></mxCell><mxCell id="9" value="为什么这样设计" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1170" y="180" width="390" height="54" as="geometry"/></mxCell><mxCell id="10" value="Tesla feed 不可用" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="254" width="250" height="120" as="geometry"/></mxCell><mxCell id="11" value="Manual SOS / 晚到通知 / 口述" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="330" y="254" width="280" height="120" as="geometry"/></mxCell><mxCell id="12" value="最小事故录入表单 -&gt; Low-fidelity IncidentContext" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="630" y="254" width="520" height="120" as="geometry"/></mxCell><mxCell id="13" value="保证事故能启动" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1170" y="254" width="390" height="120" as="geometry"/></mxCell><mxCell id="14" value="网络不可用" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="392" width="250" height="120" as="geometry"/></mxCell><mxCell id="15" value="离线证据与待发送队列" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="330" y="392" width="280" height="120" as="geometry"/></mxCell><mxCell id="16" value="Durable Incident Store -&gt; Recovery Scheduler -&gt; 网络恢复补发" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="630" y="392" width="520" height="120" as="geometry"/></mxCell><mxCell id="17" value="不丢事故材料" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1170" y="392" width="390" height="120" as="geometry"/></mxCell><mxCell id="18" value="connector token 失效" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="530" width="250" height="120" as="geometry"/></mxCell><mxCell id="19" value="进入 assisted mode" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="330" y="530" width="280" height="120" as="geometry"/></mxCell><mxCell id="20" value="提示重新登录或切人工 -&gt; 保持 ClaimDraft/RepairPlan 不丢" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="630" y="530" width="520" height="120" as="geometry"/></mxCell><mxCell id="21" value="不让流程 silently fail" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1170" y="530" width="390" height="120" as="geometry"/></mxCell><mxCell id="22" value="审批超时" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="668" width="250" height="120" as="geometry"/></mxCell><mxCell id="23" value="挂起高风险动作" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="330" y="668" width="280" height="120" as="geometry"/></mxCell><mxCell id="24" value="PendingApproval 标记 TIMEOUT -&gt; 持续提醒 -&gt; 不自动继续" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="630" y="668" width="520" height="120" as="geometry"/></mxCell><mxCell id="25" value="保持风险边界" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1170" y="668" width="390" height="120" as="geometry"/></mxCell><mxCell id="26" value="进程被杀 / 手机重启" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="806" width="250" height="120" as="geometry"/></mxCell><mxCell id="27" value="从 durable state 恢复" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="330" y="806" width="280" height="120" as="geometry"/></mxCell><mxCell id="28" value="Watchdog -&gt; Recovery Service -&gt; 继续未完成任务" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="630" y="806" width="520" height="120" as="geometry"/></mxCell><mxCell id="29" value="跨天和中断后仍可续跑" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1170" y="806" width="390" height="120" as="geometry"/></mxCell><mxCell id="30" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="32" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="34" value="说明一个可信的事故系统一定要把失败设计成主路径之一，而不是只画成功链路。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="36" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="38" value="连接器失效、网络断开、审批超时、进程被杀等失败事件。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="40" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="42" value="可解释的降级动作和恢复路径。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="44" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="46" value="1. 失败事件 -&gt; 失败分类器 | 具体失败原因 | 得到失败类型&lt;br&gt;2. 失败分类器 -&gt; 对应回退路径 | 失败类型 | 进入降级链&lt;br&gt;3. 回退路径 -&gt; Durable Store / UI / Scheduler | 降级任务 | 可恢复状态保存&lt;br&gt;4. 恢复条件满足后 -&gt; 主流程 | 网络恢复、重新登录、用户审批 | 事故流程继续" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="116" as="geometry"/></mxCell><mxCell id="48" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="698" width="860" height="28" as="geometry"/></mxCell><mxCell id="50" value="失败分类器 | 识别是 feed、网络、token、审批还是进程问题 | 入:错误事件 | 出:失败类型 | 例:token_expired&lt;br&gt;Assisted Mode UI | 在无法自动化时引导用户接管 | 入:失败类型和上下文 | 出:人工操作界面 | 例:提示重新登录 Geico&lt;br&gt;Durable Incident Store | 保存未完成上下文 | 入:失败前状态 | 出:待恢复状态 | 例:ClaimDraft 不丢&lt;br&gt;Recovery Scheduler | 条件恢复后重新触发任务 | 入:恢复条件 | 出:恢复任务 | 例:网络恢复后补发" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="732" width="860" height="116" as="geometry"/></mxCell><mxCell id="52" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="860" width="860" height="28" as="geometry"/></mxCell><mxCell id="54" value="输入例子: failure='network_unavailable'&lt;br&gt;输出例子: queue='pending_claim_submit', next_retry='when network back'" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="894" width="860" height="76" as="geometry"/></mxCell><mxCell id="56" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="982" width="860" height="28" as="geometry"/></mxCell><mxCell id="58" value="已有: Approval timeout、TaskLog 等基础概念存在&lt;br&gt;stub: 没有统一失败分类与离线队列&lt;br&gt;目标态: 离线队列、Assisted Mode、Watchdog 恢复" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1016" width="860" height="96" as="geometry"/></mxCell><mxCell id="60" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1124" width="860" height="28" as="geometry"/></mxCell><mxCell id="62" value="如果不画失败链，读者会以为只要接好 connector 就一定成功，这是最危险的架构幻觉之一。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1158" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="23-当前-android-agent-组件映射" name="23 当前 android-agent 组件映射"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="23 当前 android-agent 组件映射" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把事故场景中的每个关键层映射回当前仓库，明确已有、stub 和缺失项。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="当前已有" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="8