k;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="27" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="15" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="28" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="16" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="29" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="17" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="30" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="16" target="17" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="32" value="总图阅读法&lt;br&gt;先只看粗箭头: 事故如何进入手机、手机如何形成 IncidentContext、再如何分成多条处理链。&lt;br&gt;后面的每一页，都是在把这张图里的一个框或一条链拆开。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="850" width="1660" height="110" as="geometry"/></mxCell><mxCell id="33" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="35" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="37" value="回答最核心的问题：黄石事故如果交给手机 Agent 处理，整条链路上到底有哪些大组件和大阶段。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="39" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="41" value="CrashSnapshot、Manual SOS、原行程、用户资料、保险引用、GPS 位置。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="43" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="45" value="SummaryCard，以及可追溯的 IncidentTimeline、EvidenceBundle 和 RepairPlan。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="47" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="49" value="1. 事故触发 -&gt; Emergency Intake Broker | 碰撞信号或手动 SOS | 得到第一份 CrashSnapshot&lt;br&gt;2. Emergency Intake Broker -&gt; EmergencyMode UI + AgentForegroundService | 事故事实和用户确认请求 | 手机进入紧急模式&lt;br&gt;3. 宿主运行时 -&gt; IncidentContext | 时间、位置、用户答复、保单和行程引用 | 形成 IncidentContext&lt;br&gt;4. IncidentContext -&gt; 主控和专项 Agent | 事故主上下文 | 得到紧急、保险、拖车和行程子任务&lt;br&gt;5. 工具控制层 -&gt; 连接器 / 系统服务 / 审计 | 每个子任务的工具调用 | 形成 SummaryCard 和时间线" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="51" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="53" value="Emergency Intake Broker | 统一处理事故入口 | 入:Tesla feed / 手动 SOS / 通知事件 | 出:CrashSnapshot + IncidentContext 草稿 | 例:把 I-90 MM247 的事故接住&lt;br&gt;AgentForegroundService | 事故流程的宿主 | 入:启动请求 | 出:持续运行的服务上下文 | 例:保证等待拖车期间流程不断&lt;br&gt;AgentOrchestrator | 当前代码中的执行主循环 | 入:goal + observations | 出:下一步工具调用 | 例:当前最接近主控逻辑的组件&lt;br&gt;专项 Agent | 按业务拆分事故任务 | 入:IncidentContext | 出:ClaimDraft / RepairPlan / TravelAdjustmentPlan | 例:保险 Agent 生成理赔草稿&lt;br&gt;SummaryCard | 把所有子任务收口给用户 | 入:酒店、餐饮、租车、理赔号 | 出:一张可读通知卡片 | 例:今晚住哪、明天几点取车" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="136" as="geometry"/></mxCell><mxCell id="55" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="900" width="860" height="28" as="geometry"/></mxCell><mxCell id="57" value="输入例子: CrashSnapshot={time:14:34, lat:45.84, lng:-107.92, source:tesla}&lt;br&gt;输出例子: SummaryCard={hotel:Marriott, dinner:Walker's Grill 19:00, claim_id:GE-2024-87421}" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="934" width="860" height="76" as="geometry"/></mxCell><mxCell id="59" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1022" width="860" height="28" as="geometry"/></mxCell><mxCell id="61" value="已有: MvpRuntime、AgentOrchestrator、ToolDispatcher、ApprovalCoordinator、TaskLog&lt;br&gt;stub: AgentForegroundService 空壳、短信/拍照等高风险工具多为 stub&lt;br&gt;目标态: IncidentCoordinator、多 Agent、外部连接器、durable 恢复" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1056" width="860" height="96" as="geometry"/></mxCell><mxCell id="63" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1164" width="860" height="28" as="geometry"/></mxCell><mxCell id="65" value="最容易误读的是把总图里所有框都当成当前已实现；实际上只有中间这层运行时是当前真实存在的。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1198" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="03-名词表与颜色图例" name="03 名词表与颜色图例"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="03 名词表与颜色图例" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="先把后面 22 页会反复出现的术语、颜色和数据对象讲清楚。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="绿色
当前已有实现" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=16;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="220" width="260" height="90" as="geometry"/></mxCell><mxCell id="7" value="黄色
stub / 半成品 / 需要审批" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=16;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="390" y="220" width="260" height="90" as="geometry"/></mxCell><mxCell id="8" value="橙色
目标态 / 外部连接器 / OEM 能力" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=16;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="700" y="220" width="260" height="90" as="geometry"/></mxCell><mxCell id="9" value="蓝色
数据对象 / 状态 / 控制信息" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=16;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1010" y="220" width="260" height="90" as="geometry"/></mxCell><mxCell id="10" value="红色
风险 / 失败 / 容易误解" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=16;strokeColor=#ef4444;fillColor=#fee2e2;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1320" y="220" width="260" height="90" as="geometry"/></mxCell><mxCell id="11" value="高频名词" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=18;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="380" width="200" height="28" as="geometry"/></mxCell><mxCell id="12" value="CrashSnapshot" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=16;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="430" width="220" height="56" as="geometry"/></mxCell><mxCell id="14" value="含义: 事故触发时的第一份快照。&lt;br&gt;谁生产: Tesla Connector / Manual SOS&lt;br&gt;谁消费: Emergency Intake Broker / IncidentContext builder&lt;br&gt;例子: I-90 MM247, 14:34, side=front-left" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="320" y="430" width="460" height="110" as="geometry"/></mxCell><mxCell id="15" value="IncidentContext" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=16;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="840" y="430" width="220" height="56" as="geometry"/></mxCell><mxCell id="17" value="含义: 事故流程的主上下文对象。&lt;br&gt;谁生产: Emergency Intake Broker&lt;br&gt;谁消费: MasterAgent / 各专项 Agent&lt;br&gt;例子: incident_id=ys-2026-0314-001" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1080" y="430" width="460" height="110" as="geometry"/></mxCell><mxCell id="18" value="Observation" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=16;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="600" width="220" height="56" as="geometry"/></mxCell><mxCell id="20" value="含义: 每次工具执行后的新事实。&lt;br&gt;谁生产: ToolRuntime / 服务监听器&lt;br&gt;谁消费: AgentOrchestrator / 事件总线&lt;br&gt;例子: kind=notifications.list" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="320" y="600" width="460" height="110" as="geometry"/></mxCell><mxCell id="21" value="TaskContext" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=16;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="840" y="600" width="220" height="56" as="geometry"/></mxCell><mxCell id="23" value="含义: 当前 orchestrator 单次任务上下文。&lt;br&gt;谁生产: AgentOrchestrator&lt;br&gt;谁消费: Planner / ToolDispatcher&lt;br&gt;例子: goal=incident.handle" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1080" y="600" width="460" height="110" as="geometry"/></mxCell><mxCell id="24" value="PendingApproval" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=16;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="770" width="220" height="56" as="geometry"/></mxCell><mxCell id="26" value="含义: 尚未完成的审批请求。&lt;br&gt;谁生产: ApprovalCoordinator&lt;br&gt;谁消费: UI / Scheduler / MasterAgent&lt;br&gt;例子: approval=share-location-to-sarah" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="320" y="770" width="460" height="110" as="geometry"/></mxCell><mxCell id="27" value="ApprovalDecision" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=16;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="840" y="770" width="220" height="56" as="geometry"/></mxCell><mxCell id="29" value="含义: 审批结果。&lt;br&gt;谁生产: 用户 / 系统审批服务&lt;br&gt;谁消费: ApprovalCoordinator / 任务恢复逻辑&lt;br&gt;例子: decision=ALLOW_ONCE" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1080" y="770" width="460" height="110" as="geometry"/></mxCell><mxCell id="31" value="完整名词表、角色表和核心数据对象表在配套 markdown 里有完整版本。&lt;br&gt;这页只把后续 25 页里最常见的颜色和高频对象先讲清楚。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="980" width="1580" height="90" as="geometry"/></mxCell><mxCell id="32" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="34" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="36" value="避免读者因为名词漂移而读不懂图。看完这页之后，后面每一页的术语和颜色都能对上。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="38" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="40" value="图上的颜色块、组件名、数据对象名。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="42" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="44" value="统一的术语理解：知道 CrashSnapshot、IncidentContext、SummaryCard 各是什么。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="46" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="48" value="1. 读者 -&gt; 颜色图例 | 绿色/黄色/橙色/蓝色/红色 | 能区分已有与目标态&lt;br&gt;2. 颜色图例 -&gt; 核心名词表 | 组件与数据对象名 | 建立统一词典&lt;br&gt;3. 核心名词表 -&gt; 后续页面 | 标准术语 | 读图时不迷糊" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="96" as="geometry"/></mxCell><mxCell id="50" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="678" width="860" height="28" as="geometry"/></mxCell><mxCell id="52" value="颜色图例 | 说明方框颜色的语义 | 入:颜色 | 出:状态判断 | 例:橙色代表目标态连接器&lt;br&gt;核心数据对象表 | 说明主数据对象的含义 | 入:对象名 | 出:对象解释 | 例:CrashSnapshot 是事故瞬时快照&lt;br&gt;角色表 | 说明谁在系统里负责什么 | 入:角色名 | 出:角色职责 | 例:MasterAgent 负责总协调" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="712" width="860" height="96" as="geometry"/></mxCell><mxCell id="54" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="820" width="860" height="28" as="geometry"/></mxCell><mxCell id="56" value="输入例子: 看到一个蓝色框写 IncidentContext&lt;br&gt;输出例子: 你知道它表示“事故主上下文数据”，而不是某个代码类已经完整实现" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="854" width="860" height="76" as="geometry"/></mxCell><mxCell id="58" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="942" width="860" height="28" as="geometry"/></mxCell><mxCell id="60" value="已有: 颜色语义、当前代码类名&lt;br&gt;stub: 无&lt;br&gt;目标态: 整套图统一使用同一术语" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="976" width="860" height="96" as="geometry"/></mxCell><mxCell id="62" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1084" width="860" height="28" as="geometry"/></mxCell><mxCell id="64" value="最容易误解的是把蓝色框看成“数据库已经存在”，其实蓝色更多表示抽象数据对象或控制状态。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1118" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="04-合理性与实现前提" name="04 合理性与实现前提"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="04 合理性与实现前提" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="先把故事里最乐观的假设挑出来，一个个修正成工程上能落地的前提。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="故事里的假设" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="60" y="180" width="420" height="54" as="geometry"/></mxCell><mxCell id="7" value="合理性判断" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="500" y="180" width="480" height="54" as="geometry"/></mxCell><mxCell id="8" value="需要补的工程前提" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1000" y="180" width="560" height="54" as="geometry"/></mxCell><mxCell id="9" value="Tesla 一撞，手机立刻收到实时数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="254" width="420" height="110" as="geometry"/></mxCell><mxCell id="10" value="只有在 Tesla 官方 API、车端配对或 OEM 协同时才成立。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="500" y="254" width="480" height="110" as="geometry"/></mxCell><mxCell id="11" value="需要 Tesla Connector + pair trust；否则要有 Manual SOS 回退。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1000" y="254" width="560" height="110" as="geometry"/></mxCell><mxCell id="12" value="锁屏直接弹紧急界面且流程不断" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="382" width="420" height="110" as="geometry"/></mxCell><mxCell id="13" value="普通三方 App 不稳定。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="500" y="382" width="480" height="110" as="geometry"/></mxCell><mxCell id="14" value="需要系统级保活、锁屏展示、音频播报和后台唤醒。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1000" y="382" width="560" height="110" as="geometry"/></mxCell><mxCell id="15" value="AI 自动拨 911 并完整代答" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="510" width="420" height="110" as="geometry"/></mxCell><mxCell id="16" value="高风险，不宜默认自动。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="500" y="510" width="480" height="110" as="geometry"/></mxCell><mxCell id="17" value="要有 RiskPolicy、Approval 和 assisted mode。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1000" y="510" width="560" height="110" as="geometry"/></mxCell><mxCell id="18" value="手机可以直接控制 Tesla 摄像头" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="638" width="420" height="110" as="geometry"/></mxCell><mxCell id="19" value="不合理。车载摄像头不属于手机。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="500" y="638" width="480" height="110" as="geometry"/></mxCell><mxCell id="20" value="车端证据流和手机证据流要分开。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1000" y="638" width="560" height="110" as="geometry"/></mxCell><mxCell id="21" value="保险/拖车/酒店都能自动完成" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="766" width="420" height="110" as="geometry"/></mxCell><mxCell id="22" value="只有 token、权限、支付条件都满足才行。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="500" y="766" width="480" height="110" as="geometry"/></mxCell><mxCell id="23" value="每类连接器都要有 credential state、审批点和失败回退。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1000" y="766" width="560" height="110" as="geometry"/></mxCell><mxCell id="24" value="6 个 Agent 现在就能并行" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="894" width="420" height="110" as="geometry"/></mxCell><mxCell id="25" value="当前代码没有 subagent coordinator。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="500" y="894" width="480" height="110" as="geometry"/></mxCell><mxCell id="26" value="只能把多 Agent 画成目标态，当前近似映射是单 orchestrator。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1000" y="894" width="560" height="110" as="geometry"/></mxCell><mxCell id="27" value="过 1~2 天系统能自己恢复旅途" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="60" y="1022" width="420" height="110" as="geometry"/></mxCell><mxCell id="28" value="当前没有 durable store，做不到可靠恢复。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="500" y="1022" width="480" height="110" as="geometry"/></mxCell><mxCell id="29" value="必须增加 durable incident store、approval store 和 recovery scheduler。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=13;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1000" y="1022" width="560" height="110" as="geometry"/></mxCell><mxCell id="30" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="32" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="34" value="先把不合理或过于理想化的地方挑出来，避免后面画出的数据流失真。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="36" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="38" value="业务故事中的乐观假设。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="40" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="42" value="一组更接近真实工程条件的前提约束。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="44" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="46" value="1. 业务故事 -&gt; 合理性审查 | 每个乐观假设 | 得到风险列表&lt;br&gt;2. 合理性审查 -&gt; 工程前提 | 风险列表 | 得到系统要求&lt;br&gt;3. 工程前提 -&gt; 后续图页 | 修正后的边界 | 避免画出伪闭环" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="96" as="geometry"/></mxCell><mxCell id="48" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="678" width="860" height="28" as="geometry"/></mxCell><mxCell id="50" value="合理性审查 | 把故事改写成工程约束 | 入:业务设定 | 出:风险点 | 例:自动 911 属于高风险&lt;br&gt;工程前提 | 给每个风险补一条系统要求 | 入:风险点 | 出:需要补的能力 | 例:加 durable store 才能跨天恢复&lt;br&gt;后续图页 | 消费这些前提继续拆图 | 入:前提列表 | 出:更真实的数据流 | 例:第 17 页会明确依赖 recovery scheduler" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="712" width="860" height="96" as="geometry"/></mxCell><mxCell id="52" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="820" width="860" height="28" as="geometry"/></mxCell><mxCell id="54" value="输入例子: “自动接收 Tesla 撞车数据”&lt;br&gt;输出例子: “需要 connector；没有 connector 时走 Manual SOS”" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="854" width="860" height="76" as="geometry"/></mxCell><mxCell id="56" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="942" width="860" height="28" as="geometry"/></mxCell><mxCell id="58" value="已有: RiskPolicy、Approval、单 orchestrator、内存态 log/store&lt;br&gt;stub: AgentForegroundService 空壳、部分工具 stub&lt;br&gt;目标态: 连接器、长任务恢复、系统级入口" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="976" width="860" height="96" as="geometry"/></mxCell><mxCell id="60" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1084" width="860" height="28" as="geometry"/></mxCell><mxCell id="62" value="如果跳过这页，后面很容易把目标态设计看成当前真能跑起来的产品。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1118" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="05-触发与紧急模式总览" name="05 触发与紧急模式总览"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="05 触发与紧急模式总览" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="先看事故入口的大框架：事故怎么进入手机，手机怎么进入紧急模式。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="Tesla Connector" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="250" width="240" height="88" as="geometry"/></mxCell><mxCell id="7" value="Manual SOS / Tesla App 通知" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="410" width="240" height="88" as="geometry"/></mxCell><mxCell id="8" value="Emergency Intake Broker" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="420" y="330" width="280" height="96" as="geometry"/></mxCell><mxCell id="9" value="AgentForegroundService" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="820" y="250" width="260" height="92" as="geometry"/></mxCell><mxCell id="10" value="EmergencyMode UI" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="820" y="410" width="260" height="92" as="geometry"/></mxCell><mxCell id="11" value="Seed IncidentContext" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1180" y="330" width="300" height="96" as="geometry"/></mxCell><mxCell id="12" value="MvpRuntime" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="650" width="240" height="88" as="geometry"/></mxCell><mxCell id="13" value="AgentOrchestrator.runTask" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="420" y="650" width="280" height="96" as="geometry"/></mxCell><mxCell id="14" value="IncidentCoordinator
目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="820" y="650" width="260" height="92" as="geometry"/></mxCell><mxCell id="15" value="TaskLog / Observation" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1180" y="650" width="300" height="96" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="24" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="13" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="25" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="15" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="27" value="这一页先看总览&lt;br&gt;你先只需要知道：入口可能来自 Tesla，也可能来自人工；两条路最后都要变成同一种 Seed IncidentContext。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="860" width="1420" height="90" as="geometry"/></mxCell><mxCell id="28" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="30" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="32" value="说明事故从哪里进来，以及手机端最先启动的是哪些组件。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="34" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="36" value="Tesla feed、手动 SOS、通知触发、用户口头确认。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="38" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="40" value="Seed IncidentContext，以及被唤起的手机端宿主和 orchestrator。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="42" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="44" value="1. Tesla Connector 或 Manual SOS -&gt; Emergency Intake Broker | CrashSnapshot 或求救事件 | 得到标准入口事件&lt;br&gt;2. Emergency Intake Broker -&gt; AgentForegroundService | 事故入口事件 | 服务进入前台或准备保活&lt;br&gt;3. Emergency Intake Broker -&gt; EmergencyMode UI | 事故入口事件 | 用户看到红色警报或确认卡片&lt;br&gt;4. ForegroundService + UI -&gt; Seed IncidentContext | 位置、时间、用户答复、基础资料引用 | 形成 Seed IncidentContext&lt;br&gt;5. Seed IncidentContext -&gt; MvpRuntime / AgentOrchestrator | 事故主上下文 | 进入 incident.handle" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="46" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="48" value="Tesla Connector | 接车端事故信号 | 入:车辆遥测或官方通知 | 出:CrashSnapshot | 例:时间=14:34, 气囊信号=true&lt;br&gt;Emergency Intake Broker | 统一事故入口 | 入:车端 feed、手动 SOS | 出:Seed IncidentContext 草稿 | 例:把 Tesla 和人工入口变成同格式&lt;br&gt;EmergencyMode UI | 让用户立刻意识到事故流程已启动 | 入:事故告警 | 出:用户确认、用户状态 | 例:“您还好吗，需要帮助吗？”&lt;br&gt;AgentForegroundService | 给流程一个持续宿主 | 入:启动命令 | 出:活跃的 Android service | 例:避免切到后台就丢流程&lt;br&gt;AgentOrchestrator | 当前代码中最接近主控的一层 | 入:TaskContext | 出:下一步工具选择 | 例:先记日志，再找下一步" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="136" as="geometry"/></mxCell><mxCell id="50" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="900" width="860" height="28" as="geometry"/></mxCell><mxCell id="52" value="输入例子: source=manual_sos, location=I-90 MM247, user_tap=需要帮助&lt;br&gt;输出例子: Seed IncidentContext={incident_id, location, user_status=unknown_then_confirmed}" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="934" width="860" height="76" as="geometry"/></mxCell><mxCell id="54" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1022" width="860" height="28" as="geometry"/></mxCell><mxCell id="56" value="已有: MvpRuntime、AgentOrchestrator&lt;br&gt;stub: AgentForegroundService 空壳&lt;br&gt;目标态: Tesla Connector、Emergency Intake Broker、EmergencyMode UI" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1056" width="860" height="96" as="geometry"/></mxCell><mxCell id="58" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1164" width="860" height="28" as="geometry"/></mxCell><mxCell id="60" value="很多人会把 UI 当成入口本身；其实真正负责统一数据的是 Intake Broker，而 UI 只是确认和提示面板。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1198" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="06-触发流详细步骤" name="06 触发流详细步骤"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="06 触发流详细步骤" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把事故入口再拆细，逐跳说明一份事故数据如何从入口走到 orchestrator。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="Tesla Connector" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="60" y="240" width="220" height="82" as="geometry"/></mxCell><mxCell id="7" value="Manual SOS" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="60" y="380" width="220" height="82" as="geometry"/></mxCell><mxCell id="8" value="Tesla App Notification" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="60" y="520" width="220" height="82" as="geometry"/></mxCell><mxCell id="9" value="Emergency Intake Broker" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="360" y="380" width="260" height="92" as="geometry"/></mxCell><mxCell id="10" value="Capability Check
权限/网络/定位/服务状态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="700" y="240" width="300" height="92" as="geometry"/></mxCell><mxCell id="11" value="AgentForegroundService" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="700" y="380" width="300" height="92" as="geometry"/></mxCell><mxCell id="12" value="EmergencyMode UI
语音播报/确认按钮" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="700" y="520" width="300" height="92" as="geometry"/></mxCell><mxCell id="13" value="Seed IncidentContext Builder" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1080" y="380" width="320" height="96" as="geometry"/></mxCell><mxCell id="14" value="MvpRuntime" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1490" y="300" width="220" height="82" as="geometry"/></mxCell><mxCell id="15" value="AgentOrchestrator.runTask" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1490" y="460" width="220" height="82" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="24" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="25" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="26" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="14" target="15" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="28" value="这里要特别注意&lt;br&gt;Capability Check 不是可有可无的修饰层。&lt;br&gt;它决定当前手机是否具备定位、联系人、网络、前台服务等后续条件。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#ef4444;fillColor=#fee2e2;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="70" y="820" width="1630" height="110" as="geometry"/></mxCell><mxCell id="29" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="31" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="33" value="把触发流拆到逐跳级别，让人看清每一步为何存在、输入输出是什么。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="35" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="37" value="三类触发源：Tesla Connector、Manual SOS、Tesla App Notification。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="39" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="41" value="AgentOrchestrator 接到一个可运行的 incident.handle 任务。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="43" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="45" value="1. 触发源 -&gt; Emergency Intake Broker | CrashSnapshot / SOS / 通知内容 | 统一入口事件&lt;br&gt;2. Emergency Intake Broker -&gt; Capability Check | 统一入口事件 | 得到可用能力矩阵&lt;br&gt;3. Emergency Intake Broker -&gt; AgentForegroundService | 统一入口事件 | 前台服务被拉起&lt;br&gt;4. Emergency Intake Broker -&gt; EmergencyMode UI | 统一入口事件 | 得到用户状态&lt;br&gt;5. Capability Check + Service + UI -&gt; Seed IncidentContext Builder | 位置、时间、权限状态、用户答复 | Seed IncidentContext" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="47" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="49" value="Capability Check | 核对当前环境是否能继续 | 入:权限/网络/服务状态 | 出:可用能力矩阵 | 例:定位没开就标记为 pending&lt;br&gt;Seed IncidentContext Builder | 把分散信息拼成一份事故主上下文 | 入:位置、用户状态、原行程引用 | 出:Seed IncidentContext | 例:incident_id=ys-001&lt;br&gt;MvpRuntime | 装配 orchestrator、log、approval | 入:应用上下文 | 出:可调用的 runtime 组件 | 例:返回 RuntimeComponents&lt;br&gt;AgentOrchestrator.runTask | 开始当前代码的主循环 | 入:taskId、goal、executionContext | 出:RunTaskResult | 例:goal=incident.handle" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="116" as="geometry"/></mxCell><mxCell id="51" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="880" width="860" height="28" as="geometry"/></mxCell><mxCell id="53" value="输入例子: notification='Tesla collision detected'; permissions={location:true, sms:false}&lt;br&gt;输出例子: TaskContext.goal='incident.handle'; observations 初始包含 crash.detected 和 device.capability" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="914" width="860" height="76" as="geometry"/></mxCell><mxCell id="55" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1002" width="860" height="28" as="geometry"/></mxCell><mxCell id="57" value="已有: MvpRuntime、AgentOrchestrator、部分权限检查&lt;br&gt;stub: AgentForegroundService 仅有最小 Service 壳&lt;br&gt;目标态: Intake Broker、紧急 UI、能力矩阵持久化" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1036" width="860" height="96" as="geometry"/></mxCell><mxCell id="59" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1144" width="860" height="28" as="geometry"/></mxCell><mxCell id="61" value="如果没有 Capability Check，后面很容易默认认为短信、定位、网络、相机都能用，实际会在第一分钟就断裂。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1178" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="07-无-tesla-feed-的降级流" name="07 无 Tesla feed 的降级流"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="07 无 Tesla feed 的降级流" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="说明没有车端实时数据时，系统如何仍然保住最低可用闭环。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="用户手动 SOS" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="260" width="220" height="82" as="geometry"/></mxCell><mxCell id="7" value="Tesla App 晚到通知" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="410" width="220" height="82" as="geometry"/></mxCell><mxCell id="8" value="用户口述位置与伤情" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="560" width="220" height="82" as="geometry"/></mxCell><mxCell id="9" value="降级 Intake Flow" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#ef4444;fillColor=#fee2e2;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="410" y="410" width="260" height="92" as="geometry"/></mxCell><mxCell id="10" value="最小事故录入表单" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="780" y="260" width="280" height="92" as="geometry"/></mxCell><mxCell id="11" value="语音问答采集" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="780" y="410" width="280" height="92" as="geometry"/></mxCell><mxCell id="12" value="location.get / 手动位置修正" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="780" y="560" width="280" height="92" as="geometry"/></mxCell><mxCell id="13" value="Low-fidelity IncidentContext" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1170" y="410" width="320" height="96" as="geometry"/></mxCell><mxCell id="14" value="MvpRuntime + AgentOrchestrator" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1540" y="410" width="260" height="96" as="geometry"/></mxCell><mxCell id="15" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="24" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="26" value="降级不等于失败&lt;br&gt;没有 Tesla feed 时，系统依旧可以通过手动 SOS、晚到通知和口述信息建立“低保真 IncidentContext”。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="840" width="1710" height="90" as="geometry"/></mxCell><mxCell id="27" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="29" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="31" value="证明事故场景不能只依赖车端 feed；即使车端没来，手机也要能启动最低可用闭环。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="33" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="35" value="手动 SOS、晚到的 Tesla 通知、用户口述信息。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="37" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="39" value="一份低保真但可继续执行的 IncidentContext。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="41" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="43" value="1. 手动 SOS / 晚到通知 / 用户口述 -&gt; 降级 Intake Flow | 残缺的事故信息 | 进入降级入口&lt;br&gt;2. 降级 Intake Flow -&gt; 最小事故录入表单 | 事故入口 | 表单字段&lt;br&gt;3. 降级 Intake Flow -&gt; 语音问答采集 | 事故入口 | 口述结构化结果&lt;br&gt;4. 降级 Intake Flow -&gt; location.get / 手动修正 | 事故入口 | 地理位置&lt;br&gt;5. 表单 + 问答 + 位置 -&gt; Low-fidelity IncidentContext | 手工采集结果 | 低保真 IncidentContext" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="45" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="47" value="降级 Intake Flow | 没有车端 feed 时的统一入口 | 入:SOS、口述、晚到通知 | 出:低保真事故入口事件 | 例:按钮触发紧急模式&lt;br&gt;最小事故录入表单 | 收集最少必要事实 | 入:位置、伤情、车辆是否可移动 | 出:结构化表单值 | 例:是否需要救护车&lt;br&gt;语音问答采集 | 降低受惊用户的输入成本 | 入:用户语音 | 出:结构化问答结果 | 例:“我在 I-90，车还能动吗？”&lt;br&gt;Low-fidelity IncidentContext | 承认信息不完整但允许继续处理 | 入:表单、口述、位置 | 出:事故上下文 | 例:source=manual_degraded" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="116" as="geometry"/></mxCell><mxCell id="49" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="880" width="860" height="28" as="geometry"/></mxCell><mxCell id="51" value="输入例子: 用户只知道“我在 I-90，附近 100 英里外是黄石，车前脸撞了”&lt;br&gt;输出例子: IncidentContext.location='I-90 MM247 approx', injury_status='unknown', vehicle_movable='unknown'" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="914" width="860" height="76" as="geometry"/></mxCell><mxCell id="53" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1002" width="860" height="28" as="geometry"/></mxCell><mxCell id="55" value="已有: MvpRuntime、AgentOrchestrator&lt;br&gt;stub: 手动 goal 输入可以模拟&lt;br&gt;目标态: 降级入口、语音问答、位置修正、低保真 IncidentContext builder" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1036" width="860" height="96" as="geometry"/></mxCell><mxCell id="57" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1144" width="860" height="28" as="geometry"/></mxCell><mxCell id="59" value="最容易误解的是把“没有车端 feed”当成系统彻底失效；真正合理的设计是退化但不停摆。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1178" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="08-主控工作流与并行子任务" name="08 主控工作流与并行子任务"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="08 主控工作流与并行子任务" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把故事里的 6 个专项 Agent 和当前仓库里的单 orchestrator 严格区分开。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="MvpRuntime" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="220" width="220" height="82" as="geometry"/></mxCell><mxCell id="7" value="AgentOrchestrator" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="360" y="220" width="220" height="82" as="geometry"/></mxCell><mxCell id="8" value="RecipeRegistry / Planner" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="380" width="220" height="82" as="geometry"/></mxCell><mxCell id="9" value="ToolDispatcher" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="360" y="380" width="220" height="82" as="geometry"/></mxCell><mxCell id="10" value="RiskPolicy + Approval" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="540" width="220" height="82" as="geometry"/></mxCell><mxCell id="11" value="TaskLog + Observation" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="360" y="540" width="220" height="82" as="geometry"/></mxCell><mxCell id="12" value="IncidentCoordinator
目标态主控" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="840" y="220" width="300" height="92" as="geometry"/></mxCell><mxCell id="13" value="Shared Incident Event Bus" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="840" y="410" width="300" height="92" as="geometry"/></mxCell><mxCell id="14" value="EmergencyAgent" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1240" y="180" width="220" height="82" as="geometry"/></mxCell><mxCell id="15" value="InsuranceAgent" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1500" y="180" width="220" height="82" as="geometry"/></mxCell><mxCell id="16" value="TowRepairAgent" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1240" y="330" width="220" height="82" as="geometry"/></mxCell><mxCell id="17" value="TripAgent" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1500" y="330" width="220" height="82" as="geometry"/></mxCell><mxCell id="18" value="LodgingAgent" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1240" y="480" width="220" height="82" as="geometry"/></mxCell><mxCell id="19" value="DiningAgent" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1500" y="480" width="220" height="82" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="24" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="25" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="7" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="26" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="27" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="28" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="15" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="29" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="16" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="30" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="17" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="31" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="18" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="32" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="19" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="33" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="14" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="34" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="15" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="35" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="16" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="36" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="17" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="37" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="18" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="38" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#94a3b8;dashed=1;" parent="1" source="19" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="40" value="严格区分当前与目标态&lt;br&gt;左侧是当前仓库真正存在的单 orchestrator 结构。&lt;br&gt;右侧是事故场景需要的 IncidentCoordinator + 专项 Agent 目标态。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#ef4444;fillColor=#fee2e2;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="820" width="1640" height="100" as="geometry"/></mxCell><mxCell id="41" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="43" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="45" value="让读者明白：故事里的“并行 6 个 Agent”不是当前代码的现状，而是目标态设计。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="47" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="49" value="IncidentContext、当前 MvpRuntime 和 AgentOrchestrator、目标态的业务拆分需求。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="51" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="53" value="一个清晰映射：当前单主循环近似承接目标态主控，未来再长出多子任务层。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="55" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="57" value="1. MvpRuntime -&gt; AgentOrchestrator | 已装配好的 runtime 组件 | 单 orchestrator 启动&lt;br&gt;2. AgentOrchestrator -&gt; ToolDispatcher / Risk / TaskLog | goal、observation、recipe | 得到逐步 observation&lt;br&gt;3. 事故目标场景 -&gt; IncidentCoordinator | 需要同时处理安全、保险、拖车、行程 | 形成主控层&lt;br&gt;4. IncidentCoordinator -&gt; 专项 Agent + Event Bus | IncidentContext | 形成并行处理结构" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="116" as="geometry"/></mxCell><mxCell id="59" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="698" width="860" height="28" as="geometry"/></mxCell><mxCell id="61" value="AgentOrchestrator | 当前唯一真实存在的任务主循环 | 入:TaskContext | 出:RunTaskResult + Observation | 例:一步步调用工具&lt;br&gt;ToolDispatcher | 执行具体工具 | 入:ToolRequest | 出:ToolResult | 例:发短信、读联系人、看通知&lt;br&gt;IncidentCoordinator | 目标态事故主控 | 入:IncidentContext | 出:子任务与共享事件 | 例:把事故拆给 6 个 agent&lt;br&gt;Shared Incident Event Bus | 共享事实和依赖 | 入:case_id、repair_eta、hotel | 出:可订阅事件 | 例:TripAgent 订阅 repair_eta" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="732" width="860" height="116" as="geometry"/></mxCell><mxCell id="63" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="860" width="860" height="28" as="geometry"/></mxCell><mxCell id="65" value="输入例子: IncidentContext={need_911, geico_policy_ref, trip_ref}&lt;br&gt;输出例子: 子任务集合={EmergencyAgent, InsuranceAgent, TowRepairAgent, TripAgent, LodgingAgent, DiningAgent}" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="894" width="860" height="76" as="geometry"/></mxCell><mxCell id="67" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="982" width="860" height="28" as="geometry"/></mxCell><mxCell id="69" value="已有: 单 orchestrator、ToolDispatcher、RiskPolicy、Approval、TaskLog&lt;br&gt;stub: 可以通过 recipe 模拟部分固定流程&lt;br&gt;目标态: IncidentCoordinator、Event Bus、多专项 Agent" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1016" width="860" height="96" as="geometry"/></mxCell><mxCell id="71" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1124" width="860" height="28" as="geometry"/></mxCell><mxCell id="73" value="如果不把左右两部分分开，读者会误以为仓库已经有成熟多 Agent 平台。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1158" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="09-t+0~3-分钟总览" name="09 T+0~3 分钟总览"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="09 T+0~3 分钟总览" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="事故后的前三分钟是最关键的并行窗口：安全、法律、证据三条链必须同时启动。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="IncidentContext" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="700" y="180" width="360" height="96" as="geometry"/></mxCell><mxCell id="7" value="紧急响应链" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=20;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="100" y="360" width="420" height="90" as="geometry"/></mxCell><mxCell id="8" value="保险准备链" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=20;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="670" y="360" width="420" height="90" as="geometry"/></mxCell><mxCell id="9" value="拖车/维修准备链" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=20;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1240" y="360" width="420" height="90" as="geometry"/></mxCell><mxCell id="10" value="911 / Sarah / 位置 / 手机证据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="100" y="520" width="420" height="110" as="geometry"/></mxCell><mxCell id="11" value="保单读取 / 理赔草稿 / 等待 police_case_id" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="670" y="520" width="420" height="110" as="geometry"/></mxCell><mxCell id="12" value="AAA 查询 / Tesla Service lookup / 租车预案" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1240" y="520" width="420" height="110" as="geometry"/></mxCell><mxCell id="13" value="RiskPolicy + Approval" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="700" y="730" width="360" height="96" as="geometry"/></mxCell><mxCell id="14" value="TaskLog + Observation + IncidentTimeline" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="700" y="900" width="360" height="96" as="geometry"/></mxCell><mxCell id="15" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="24" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="26" value="前三分钟的优先级&lt;br&gt;先保命和合规，再整理理赔和拖车预案。&lt;br&gt;行程、住宿、餐饮都要等到安全和基本外联稳定后再展开。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="90" y="1070" width="1570" height="100" as="geometry"/></mxCell><mxCell id="27" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="29" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="31" value="先给出前三分钟的总览，明确这段时间不是串行做一件事，而是三条链并行推进。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="33" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="35" value="IncidentContext，其中已经有事故、位置、紧急联系人、保单和原行程引用。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="37" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="39" value="初步安全响应、理赔草稿、拖车/维修预案，以及统一的审计时间线。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="41" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="43" value="1. IncidentContext -&gt; 紧急响应链 | 位置、伤情、紧急联系人 | 911/Sarah/初始证据启动&lt;br&gt;2. IncidentContext -&gt; 保险准备链 | 保单引用、事故事实、证据引用 | 等待案件号后提交&lt;br&gt;3. IncidentContext -&gt; 拖车/维修准备链 | 车辆状态、位置、AAA/Tesla 会员信息 | 形成 RepairPlan 草案&lt;br&gt;4. 三条链 -&gt; RiskPolicy + Approval | 各类外呼、短信、拍照、预约动作 | 得到允许、等待确认或阻塞&lt;br&gt;5. 审批后的动作 -&gt; IncidentTimeline | 结果和状态变化 | 后续页面能继续依赖这些事实" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="45" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="47" value="紧急响应链 | 优先处理生命安全与第一时间通知 | 入:位置、用户状态、联系人 | 出:911 呼叫、位置共享、手机证据 | 例:给 Sarah 发短信&lt;br&gt;保险准备链 | 先整理再提交 | 入:保单引用、事故事实 | 出:ClaimDraft | 例:先整理 Geico 草稿，等 police_case_id&lt;br&gt;拖车/维修准备链 | 先查再约 | 入:当前位置、车辆状态、会员信息 | 出:RepairPlan 草案 | 例:先查 AAA 和 Tesla 服务中心&lt;br&gt;RiskPolicy + Approval | 限制高风险动作 | 入:工具定义与风险等级 | 出:允许/待审批/拒绝 | 例:SMS send 需要确认&lt;br&gt;IncidentTimeline | 统一记账 | 入:TaskLog、Observation、审批结果 | 出:可追溯时间线 | 例:14:34 crash -&gt; 14:37 911 connected" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="136" as="geometry"/></mxCell><mxCell id="49" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="900" width="860" height="28" as="geometry"/></mxCell><mxCell id="51" value="输入例子: geico_policy_ref=G-123, emergency_contact=Sarah, gps=I-90 MM247&lt;br&gt;输出例子: emergency_started=true, claim_draft_ready=true, tow_lookup_ready=true" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="934" width="860" height="76" as="geometry"/></mxCell><mxCell id="53" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1022" width="860" height="28" as="geometry"/></mxCell><mxCell id="55" value="已有: RiskPolicy、Approval、TaskLog、部分基础工具&lt;br&gt;stub: sms.send、camera.snap、screen.capture 多为 stub&lt;br&gt;目标态: 911、保险、AAA、Tesla Service 等外部连接器" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1056" width="860" height="96" as="geometry"/></mxCell><mxCell id="57" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1164" width="860" height="28" as="geometry"/></mxCell><mxCell id="59" value="最容易误解的是把前三分钟画成一个大盒子。真正的关键是三条链并行，而且每条链都有自己的审批点和失败回退点。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1198" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="10-紧急响应链详细流" name="10 紧急响应链详细流"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="10 紧急响应链详细流" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把 911、紧急联系人通知、位置共享和事故证据采集拆成逐跳数据流。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="IncidentContext" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="90" y="260" width="280" height="90" as="geometry"/></mxCell><mxCell id="7" value="EmergencyAgent" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="450" y="260" width="240" height="90" as="geometry"/></mxCell><mxCell id="8" value="RiskPolicyEngine" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="770" y="160" width="240" height="90" as="geometry"/></mxCell><mxCell id="9" value="ApprovalCoordinator" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="770" y="330" width="240" height="90" as="geometry"/></mxCell><mxCell id="10" value="call.place / 911 assist" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1090" y="110" width="280" height="90" as="geometry"/></mxCell><mxCell id="11" value="contacts.search" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#22c55e;fillColor=#dcfce7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1090" y="260" width="280" height="90" as="geometry"/></mxCell><mxCell id="12" value="sms.send / share location" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1090" y="410" width="280" height="90" as="geometry"/></mxCell><mxCell id="13" value="camera.snap / screen.capture" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1090" y="560" width="280" height="100" as="geometry"/></mxCell><mxCell id="14" value="IncidentTimeline + TaskLog" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1460" y="300" width="300" height="100" as="geometry"/></mxCell><mxCell id="15" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="24" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="25" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="27" value="为什么要单独拆这一页&lt;br&gt;因为紧急响应链是整个场景里最不能模糊的一段。&lt;br&gt;这里每一个动作都关系到生命安全、法律边界和第一时间证据。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="800" width="1690" height="100" as="geometry"/></mxCell><mxCell id="28" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="30" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="32" value="让读者看清紧急响应链内部的每一站：谁决定、谁审批、谁真正执行、结果记到哪里。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="34" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="36" value="IncidentContext，尤其是位置、伤情判断、紧急联系人、是否已获用户同意。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="38" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="40" value="911 呼叫状态、Sarah 通知结果、位置共享状态、首批手机证据和 IncidentTimeline 记录。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="42" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="44" value="1. IncidentContext -&gt; EmergencyAgent | 位置、伤情、联系人、证据需求 | EmergencyAgent 开始工作&lt;br&gt;2. EmergencyAgent -&gt; RiskPolicyEngine | 计划中的电话、短信、共享位置、拍照动作 | 得到策略判断&lt;br&gt;3. EmergencyAgent -&gt; ApprovalCoordinator | 需要确认的动作 | 等待一键确认或超时&lt;br&gt;4. 策略/审批通过后 -&gt; call.place / 911 assist | 位置、事故摘要、用户状态 | 得到呼叫状态&lt;br&gt;5. EmergencyAgent -&gt; contacts.search -&gt; sms.send | 紧急联系人姓名、位置摘要 | 紧急联系人被通知" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="46" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="48" value="EmergencyAgent | 专门处理生命安全和事故第一时间外联 | 入:IncidentContext | 出:紧急动作计划 | 例:优先拨 911&lt;br&gt;RiskPolicyEngine | 按风险等级决定策略 | 入:ToolDefinition | 出:allowed / requiresApproval | 例:L2 的 sms.send 需要确认&lt;br&gt;ApprovalCoordinator | 保存并等待审批 | 入:PendingApproval 请求 | 出:批准/拒绝/超时 | 例:允许向 Sarah 发定位&lt;br&gt;contacts.search | 查找联系人 | 入:姓名或标签 | 出:联系人对象 | 例:找到妻子 Sarah&lt;br&gt;IncidentTimeline | 沉淀证据和动作结果 | 入:TaskLogEvent + EvidenceRef | 出:时间线事件 | 例:14:36 向 Sarah 发出短信" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="136" as="geometry"/></mxCell><mxCell id="50" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="900" width="860" height="28" as="geometry"/></mxCell><mxCell id="52" value="输入例子: contact='Sarah', location='I-90 MM247', user_status='responsive'&lt;br&gt;输出例子: call_status='connected', sms_status='sent', evidence_refs=['photo://plate-1']" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="934" width="860" height="76" as="geometry"/></mxCell><mxCell id="54" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1022" width="860" height="28" as="geometry"/></mxCell><mxCell id="56" value="已有: contacts.search、RiskPolicy、Approval、TaskLog&lt;br&gt;stub: sms.send、camera.snap、screen.capture 目前是 stub 或半成品&lt;br&gt;目标态: call.place / 911 assist、位置共享与紧急呼叫策略" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1056" width="860" height="96" as="geometry"/></mxCell><mxCell id="58" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1164" width="860" height="28" as="geometry"/></mxCell><mxCell id="60" value="最大的误区是默认 911 可以零确认自动发起。现实中这必须受到更严格的风险和审批控制。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1198" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="11-保险准备链详细流" name="11 保险准备链详细流"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="11 保险准备链详细流" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把保单读取、理赔草稿、证据绑定和等待案件号提交拆成逐跳步骤。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="IncidentContext" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="280" width="260" height="90" as="geometry"/></mxCell><mxCell id="7" value="InsuranceAgent" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="420" y="280" width="240" height="90" as="geometry"/></mxCell><mxCell id="8" value="保险凭据 / token state" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="740" y="150" width="280" height="90" as="geometry"/></mxCell><mxCell id="9" value="Insurance Connector" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="740" y="320" width="280" height="90" as="geometry"/></mxCell><mxCell id="10" value="ClaimDraft" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="740" y="490" width="280" height="90" as="geometry"/></mxCell><mxCell id="11" value="EvidenceBundle" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1100" y="190" width="280" height="90" as="geometry"/></mxCell><mxCell id="12" value="police_case_id" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1100" y="360" width="280" height="90" as="geometry"/></mxCell><mxCell id="13" value="ApprovalCoordinator" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1100" y="530" width="280" height="90" as="geometry"/></mxCell><mxCell id="14" value="正式提交理赔" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1460" y="320" width="260" height="90" as="geometry"/></mxCell><mxCell id="15" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="13" target="14" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="25" value="保险链为什么要分“草稿”和“正式提交”&lt;br&gt;因为很多保单系统在没有 police_case_id 时可以预填，但不适合直接最终提交。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="800" width="1640" height="100" as="geometry"/></mxCell><mxCell id="26" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="28" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="30" value="说明保险链不是一上来就点“提交”，而是先读保单、整理事实和证据，再等待案件号。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="32" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="34" value="IncidentContext、保险凭据状态、证据引用、现场事实。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="36" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="38" value="ClaimDraft、claim_id（若已提交）、免赔额和租车覆盖等后续依赖信息。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="40" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="42" value="1. IncidentContext -&gt; InsuranceAgent | 保单引用、事故事实、证据引用 | InsuranceAgent 获得上下文&lt;br&gt;2. InsuranceAgent -&gt; 保险凭据 / token state | policy_ref | 知道能否直连保司&lt;br&gt;3. 保险凭据 -&gt; Insurance Connector | policy_ref + token | 拿到保单事实&lt;br&gt;4. InsuranceAgent -&gt; ClaimDraft | 事故事实 + EvidenceBundle + 对方信息 | ClaimDraft 就绪&lt;br&gt;5. police_case_id -&gt; ClaimDraft | 案件号 | 草稿可提交" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="44" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="46" value="InsuranceAgent | 负责保单读取、理赔草稿和正式提交 | 入:IncidentContext | 出:ClaimDraft / claim_id | 例:Geico 理赔链&lt;br&gt;Insurance Connector | 和保司系统对接 | 入:policy_ref、claim payload | 出:保单详情、提交结果 | 例:读取 deductible=$500&lt;br&gt;ClaimDraft | 正式提交前的理赔草稿 | 入:事故事实、证据引用、案件号 | 出:可提交的 claim payload | 例:草稿里先不放 case_id&lt;br&gt;EvidenceBundle | 供理赔系统引用的证据集合 | 入:照片、录屏、轨迹、时间线 | 出:证据包 | 例:现场照片和轨迹打成 bundle&lt;br&gt;ApprovalCoordinator | 控制正式提交 | 入:提交请求 | 出:批准/拒绝/超时 | 例:确认是否正式报 Geico" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="136" as="geometry"/></mxCell><mxCell id="48" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="900" width="860" height="28" as="geometry"/></mxCell><mxCell id="50" value="输入例子: policy_ref=Geico-001, police_case_id=MT-2024-0891&lt;br&gt;输出例子: claim_id=GE-2024-87421, deductible=500, rental_coverage=enabled" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="934" width="860" height="76" as="geometry"/></mxCell><mxCell id="52" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1022" width="860" height="28" as="geometry"/></mxCell><mxCell id="54" value="已有: Approval、TaskLog、可扩展的 connector 占位模块 integration-bridge&lt;br&gt;stub: 无真实 Insurance Connector&lt;br&gt;目标态: ClaimDraft、Geico connector、coverage 同步" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1056" width="860" height="96" as="geometry"/></mxCell><mxCell id="56" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1164" width="860" height="28" as="geometry"/></mxCell><mxCell id="58" value="最常见误区是把“能读保单”误当成“就能直接完成理赔”。理赔至少还要有证据、案件号和最终提交确认。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1198" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="12-拖车/维修准备链详细流" name="12 拖车/维修准备链详细流"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="12 拖车/维修准备链详细流" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把 AAA、Tesla Service、租车预案三条外联链说明白，并标出审批点。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="IncidentContext" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="280" width="260" height="90" as="geometry"/></mxCell><mxCell id="7" value="TowRepairAgent" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="420" y="280" width="240" height="90" as="geometry"/></mxCell><mxCell id="8" value="AAA Connector" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="760" y="160" width="280" height="90" as="geometry"/></mxCell><mxCell id="9" value="Tesla Service Lookup" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="760" y="330" width="280" height="90" as="geometry"/></mxCell><mxCell id="10" value="Rental Connector" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="760" y="500" width="280" height="90" as="geometry"/></mxCell><mxCell id="11" value="RepairPlan" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1140" y="280" width="300" height="96" as="geometry"/></mxCell><mxCell id="12" value="ApprovalCoordinator" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1140" y="470" width="300" height="90" as="geometry"/></mxCell><mxCell id="13" value="IncidentTimeline" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1520" y="280" width="240" height="90" as="geometry"/></mxCell><mxCell id="14" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="15" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="25" value="这一链的核心不是马上下单&lt;br&gt;而是先形成一个可比较、可确认的 RepairPlan：拖车去哪、维修几点、租车怎么接上。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="790" width="1680" height="100" as="geometry"/></mxCell><mxCell id="26" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="28" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="30" value="说明拖车和维修不是一个动作，而是一组相关外联调用最终形成 RepairPlan。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="32" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="34" value="事故位置、车辆状态、AAA 会员状态、Tesla 维修偏好、租车覆盖信息。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="36" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="38" value="RepairPlan，包括拖车 ETA、目的地、服务预约、租车安排。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="40" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="42" value="1. IncidentContext -&gt; TowRepairAgent | 位置、车辆状态、会员信息 | TowRepairAgent 获得上下文&lt;br&gt;2. TowRepairAgent -&gt; AAA Connector | 当前位置和会员号 | 得到 tow_eta&lt;br&gt;3. TowRepairAgent -&gt; Tesla Service Lookup | 当前位置和车型 | 得到 service_center/checkin&lt;br&gt;4. TowRepairAgent -&gt; Rental Connector | 保险覆盖和维修时间 | 得到 rental option&lt;br&gt;5. AAA/Tesla/Rental 结果 -&gt; RepairPlan | ETA、目的地、预约时间、租车信息 | RepairPlan 就绪" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="44" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="46" value="TowRepairAgent | 负责拖车、维修和租车三件事的组合协调 | 入:IncidentContext | 出:RepairPlan | 例:查 AAA + Tesla Service + Enterprise&lt;br&gt;AAA Connector | 查拖车资源 | 入:会员号、位置 | 出:拖车 ETA 与目的地候选 | 例:ETA=45 分钟&lt;br&gt;Tesla Service Lookup | 查维修中心和 check-in | 入:车型、位置 | 出:最近维修点和时间 | 例:Billings 明天 10AM&lt;br&gt;Rental Connector | 在维修期补齐代步方案 | 入:coverage、维修时长 | 出:租车候选 | 例:明天 9AM 取车&lt;br&gt;RepairPlan | 给其他链路复用的统一计划 | 入:拖车/维修/租车结果 | 出:tow_eta、service_center、rental_pickup | 例:后续酒店链会依赖它" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="136" as="geometry"/></mxCell><mxCell id="48" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="900" width="860" height="28" as="geometry"/></mxCell><mxCell id="50" value="输入例子: aaa_member=true, vehicle='Tesla Model Y', location='I-90 MM247'&lt;br&gt;输出例子: RepairPlan={tow_eta:45m, service:'Billings 10AM', rental:'Enterprise 9AM'}" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="934" width="860" height="76" as="geometry"/></mxCell><mxCell id="52" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1022" width="860" height="28" as="geometry"/></mxCell><mxCell id="54" value="已有: Approval、TaskLog、事件对象抽象可以复用&lt;br&gt;stub: 无真实 AAA / Tesla Service / Rental connector&lt;br&gt;目标态: RepairPlan、跨链依赖、自动预约" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1056" width="860" height="96" as="geometry"/></mxCell><mxCell id="56" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1164" width="860" height="28" as="geometry"/></mxCell><mxCell id="58" value="如果不把三条外联结果统一成 RepairPlan，后面的住宿和行程调整会拿不到稳定输入。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1198" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="13-t+3~20-分钟处理中总览" name="13 T+3~20 分钟处理中总览"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="13 T+3~20 分钟处理中总览" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="这段时间的核心是把零散事实变成结构化案件事实，再推动外部系统状态前进。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="现场事实输入
警方、照片、车牌、驾照、保险卡、拖车状态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="650" y="170" width="540" height="100" as="geometry"/></mxCell><mxCell id="7" value="案件事实结构化" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=20;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="160" y="420" width="420" height="100" as="geometry"/></mxCell><mxCell id="8" value="外部服务状态推进" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=20;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="780" y="420" width="420" height="100" as="geometry"/></mxCell><mxCell id="9" value="关键依赖输出
police_case_id / claim_id / repair_eta" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1400" y="420" width="320" height="100" as="geometry"/></mxCell><mxCell id="10" value="后续安排输入" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1400" y="640" width="320" height="90" as="geometry"/></mxCell><mxCell id="11" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="12" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="13" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="14" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="15" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" value="这段时间的关键变化&lt;br&gt;从“事故刚发生”变成“案件要素逐渐齐全”，很多后续步骤此时才第一次具备继续推进的条件。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="840" width="1640" height="100" as="geometry"/></mxCell><mxCell id="18" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="20" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="22" value="给中间处理阶段一个总览，明确这时最重要的是事实结构化和外部状态推进两件事。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="24" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="26" value="警察到场、用户补拍证据、外联系统开始返回状态。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="28" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="30" value="police_case_id、claim_id、repair_eta 等后续依赖输入。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="32" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="34" value="1. 现场事实输入 -&gt; 案件事实结构化 | 照片、车牌、警察沟通结果 | IncidentTimeline 更完整&lt;br&gt;2. 现场事实输入 -&gt; 外部服务状态推进 | 案件号、车辆状态、证据包 | 拿到外部系统返回&lt;br&gt;3. 案件事实结构化 + 外部状态 -&gt; 关键依赖输出 | case_id、claim_id、repair_eta | 形成共享依赖&lt;br&gt;4. 关键依赖输出 -&gt; 后续安排输入 | 维修 ETA、理赔状态、租车覆盖 | 进入第 16 页阶段" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="116" as="geometry"/></mxCell><mxCell id="36" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="698" width="860" height="28" as="geometry"/></mxCell><mxCell id="38" value="案件事实结构化 | 把零散证据和口头事实变成机器能继续用的字段 | 入:照片、证件、案件号 | 出:结构化案件事实 | 例:对方车牌被 OCR 成文本&lt;br&gt;外部服务状态推进 | 推动保司、AAA、维修点真正返回状态 | 入:案件号、证据、预约请求 | 出:claim_id / tow_eta / service_booking | 例:理赔提交成功&lt;br&gt;关键依赖输出 | 收集后续页面会用到的共享事实 | 入:结构化事实 + 外部返回 | 出:police_case_id、claim_id、repair_eta | 例:repair_eta=1~3天" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="732" width="860" height="96" as="geometry"/></mxCell><mxCell id="40" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="840" width="860" height="28" as="geometry"/></mxCell><mxCell id="42" value="输入例子: police_case_id='MT-2024-0891', plate_photo='photo://plate-1'&lt;br&gt;输出例子: claim_id='GE-2024-87421', repair_eta='1~3 days'" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="874" width="860" height="76" as="geometry"/></mxCell><mxCell id="44" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="962" width="860" height="28" as="geometry"/></mxCell><mxCell id="46" value="已有: TaskLog、Observation、可扩展事件模型&lt;br&gt;stub: OCR、外部连接器仍缺&lt;br&gt;目标态: 完整案件结构化层和跨服务状态推进层" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="996" width="860" height="96" as="geometry"/></mxCell><mxCell id="48" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1104" width="860" height="28" as="geometry"/></mxCell><mxCell id="50" value="如果没有这一层，后续安排页就会直接凭猜测做酒店和行程调整，缺少真实依赖。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1138" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="14-案件事实结构化与证据补齐" name="14 案件事实结构化与证据补齐"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="14 案件事实结构化与证据补齐" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把照片、OCR、案件号、时间线、证据包之间的关系彻底讲清楚。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="用户照片 / 录屏 / 现场输入" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="280" width="260" height="90" as="geometry"/></mxCell><mxCell id="7" value="OCR / media understanding" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="420" y="180" width="260" height="90" as="geometry"/></mxCell><mxCell id="8" value="结构化事实提取" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="420" y="360" width="260" height="90" as="geometry"/></mxCell><mxCell id="9" value="police_case_id" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="420" y="540" width="260" height="90" as="geometry"/></mxCell><mxCell id="10" value="EvidenceBundle" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="790" y="180" width="300" height="96" as="geometry"/></mxCell><mxCell id="11" value="IncidentTimeline" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="790" y="360" width="300" height="96" as="geometry"/></mxCell><mxCell id="12" value="ClaimDraft / PoliceSummary" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="790" y="540" width="300" height="96" as="geometry"/></mxCell><mxCell id="13" value="保险 / 审计 / 后续计划" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1180" y="360" width="340" height="100" as="geometry"/></mxCell><mxCell id="14" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="15" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="22" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="12" target="13" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="25" value="为什么一定要画“结构化事实提取”&lt;br&gt;因为原始照片和用户口述不能直接喂给后面的保险、审计和恢复逻辑。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="800" width="1460" height="100" as="geometry"/></mxCell><mxCell id="26" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="28" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="30" value="展示从原始证据到结构化案件事实的完整加工过程。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="32" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="34" value="现场照片、录屏、用户口述、案件号。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="36" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="38" value="EvidenceBundle、IncidentTimeline，以及可提交的 ClaimDraft 或 PoliceSummary。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="40" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="42" value="1. 用户照片 / 录屏 -&gt; OCR / media understanding | 原始媒体 | 得到可用文本&lt;br&gt;2. 原始媒体 + OCR 结果 -&gt; 结构化事实提取 | 文本和图像线索 | 得到 plate、license、insurance_card 等字段&lt;br&gt;3. 结构化字段 -&gt; EvidenceBundle | 证据引用和摘要 | 保险和审计都可用&lt;br&gt;4. 结构化字段 + police_case_id -&gt; IncidentTimeline | 时间、地点、案件号、动作结果 | 时间线更可信&lt;br&gt;5. EvidenceBundle + Timeline -&gt; ClaimDraft / PoliceSummary | 结构化事实 | 理赔草稿或陈述摘要" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="136" as="geometry"/></mxCell><mxCell id="44" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="718" width="860" height="28" as="geometry"/></mxCell><mxCell id="46" value="OCR / media understanding | 把照片和卡片里的文本识别出来 | 入:图片/录屏 | 出:可搜索文本 | 例:识别出对方车牌&lt;br&gt;结构化事实提取 | 把文本和媒体转成标准字段 | 入:OCR 文本、人工补录 | 出:plate、license、policy_card | 例:车牌=ABC123&lt;br&gt;EvidenceBundle | 把证据整理成一包 | 入:EvidenceRef 列表 | 出:bundle id | 例:bundle=claim-prep-01&lt;br&gt;IncidentTimeline | 保存正式事件顺序 | 入:TaskLog、case_id、证据 | 出:时间线 | 例:14:50 police_case_id received&lt;br&gt;ClaimDraft / PoliceSummary | 给保险和审计消费的成品对象 | 入:结构化事实 + 时间线 | 出:草稿文档 | 例:提交前给用户预览" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="752" width="860" height="136" as="geometry"/></mxCell><mxCell id="48" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="900" width="860" height="28" as="geometry"/></mxCell><mxCell id="50" value="输入例子: plate_photo='photo://plate-1', case_id='MT-2024-0891'&lt;br&gt;输出例子: extracted_plate='ABC123', claim_draft_ready=true" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="934" width="860" height="76" as="geometry"/></mxCell><mxCell id="52" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1022" width="860" height="28" as="geometry"/></mxCell><mxCell id="54" value="已有: TaskLog、Observation 的抽象可复用&lt;br&gt;stub: camera.snap / screen.capture 是 stub，暂无 OCR&lt;br&gt;目标态: OCR、证据包、结构化事实提取" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1056" width="860" height="96" as="geometry"/></mxCell><mxCell id="56" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1164" width="860" height="28" as="geometry"/></mxCell><mxCell id="58" value="如果省掉这一层，后续理赔和审计只能拿到一堆原始图片，无法稳定复用。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1198" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="15-理赔/拖车/维修外联流" name="15 理赔/拖车/维修外联流"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="15 理赔/拖车/维修外联流" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="把中期真正对外发起的调用拆开，说明谁依赖谁、谁先谁后。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="结构化案件事实" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="80" y="320" width="260" height="90" as="geometry"/></mxCell><mxCell id="7" value="Insurance Connector" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="430" y="150" width="280" height="90" as="geometry"/></mxCell><mxCell id="8" value="AAA Connector" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="430" y="320" width="280" height="90" as="geometry"/></mxCell><mxCell id="9" value="Tesla Service Connector" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="430" y="490" width="280" height="90" as="geometry"/></mxCell><mxCell id="10" value="Rental Connector" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#fb923c;fillColor=#ffedd5;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="430" y="660" width="280" height="90" as="geometry"/></mxCell><mxCell id="11" value="ApprovalCoordinator" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#f59e0b;fillColor=#fef3c7;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="830" y="320" width="300" height="96" as="geometry"/></mxCell><mxCell id="12" value="claim_id / tow_eta / service_booking / rental_booking" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=center;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1240" y="320" width="420" height="110" as="geometry"/></mxCell><mxCell id="13" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="7" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="14" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="8" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="15" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="9" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="16" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="6" target="10" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="17" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="7" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="18" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="8" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="19" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="9" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="20" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="10" target="11" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="21" style="endArrow=block;endFill=1;rounded=0;html=1;orthogonalLoop=1;jettySize=auto;strokeColor=#64748b;" parent="1" source="11" target="12" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="23" value="为什么把外联单独画一页&lt;br&gt;因为一旦真正连上外部系统，就涉及 token、失败重试、支付、用户确认和状态一致性问题。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="80" y="860" width="1580" height="100" as="geometry"/></mxCell><mxCell id="24" value="说明面板" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=18;strokeColor=#cbd5e1;fillColor=#ffffff;fontColor=#0f172a;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1840" y="120" width="900" height="1660" as="geometry"/></mxCell><mxCell id="26" value="这页在讲什么" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="170" width="860" height="28" as="geometry"/></mxCell><mxCell id="28" value="把中期阶段真正对外发请求的部分单独画出，强调依赖、审批和外部状态返回。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="204" width="860" height="76" as="geometry"/></mxCell><mxCell id="30" value="起点数据" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="292" width="860" height="28" as="geometry"/></mxCell><mxCell id="32" value="结构化案件事实、凭据状态、证据包、RepairPlan 草案。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="326" width="860" height="76" as="geometry"/></mxCell><mxCell id="34" value="终点输出" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="414" width="860" height="28" as="geometry"/></mxCell><mxCell id="36" value="claim_id、tow_eta、service_booking、rental_booking 等正式外部状态。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="448" width="860" height="76" as="geometry"/></mxCell><mxCell id="38" value="数据流步骤" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="536" width="860" height="28" as="geometry"/></mxCell><mxCell id="40" value="1. 结构化案件事实 -&gt; Insurance/AAA/Tesla Service/Rental Connector | 标准事实对象 | 外部系统收到请求&lt;br&gt;2. 各 Connector -&gt; ApprovalCoordinator | 会产生费用、提交、预约的动作 | 进入审批&lt;br&gt;3. 审批通过后 -&gt; 各 Connector | 确认结果 | 外部系统返回正式 ID&lt;br&gt;4. 外部正式返回 -&gt; 共享输出 | claim_id、tow_eta、service_booking、rental_booking | 后续安排输入齐全" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="570" width="860" height="116" as="geometry"/></mxCell><mxCell id="42" value="组件说明" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="698" width="860" height="28" as="geometry"/></mxCell><mxCell id="44" value="Insurance Connector | 和保司真正通信 | 入:ClaimDraft | 出:claim_id / deductible | 例:GE-2024-87421&lt;br&gt;AAA Connector | 提交拖车请求 | 入:位置、会员号、目的地 | 出:tow_eta | 例:ETA 45 分钟&lt;br&gt;Tesla Service Connector | 提交维修预约 | 入:车型、目的地、损伤概况 | 出:service booking | 例:Billings 明天 10AM&lt;br&gt;Rental Connector | 提交租车预订 | 入:coverage、时间窗口 | 出:rental booking | 例:明天 9AM 取车&lt;br&gt;ApprovalCoordinator | 控制最终提交/预约动作 | 入:各 connector 动作 | 出:批准/拒绝/超时 | 例:用户确认租车" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="732" width="860" height="136" as="geometry"/></mxCell><mxCell id="46" value="输入 / 输出示例" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="880" width="860" height="28" as="geometry"/></mxCell><mxCell id="48" value="输入例子: ClaimDraft + RepairPlan&lt;br&gt;输出例子: claim_id='GE-2024-87421', tow_eta='45m', service='10:00', rental='09:00'" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="914" width="860" height="76" as="geometry"/></mxCell><mxCell id="50" value="当前已有 / stub / 目标态" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1002" width="860" height="28" as="geometry"/></mxCell><mxCell id="52" value="已有: Approval 机制已存在&lt;br&gt;stub: 连接器状态机暂无实现&lt;br&gt;目标态: 保险/AAA/维修/租车连接器及其 credential state" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1036" width="860" height="96" as="geometry"/></mxCell><mxCell id="54" value="风险点 / 容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontSize=14;strokeColor=#60a5fa;fillColor=#dbeafe;fontColor=#0f172a;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="1860" y="1144" width="860" height="28" as="geometry"/></mxCell><mxCell id="56" value="没有 connector credential state 时，图上看似简单的外联实际会因为 token 失效而频繁中断。" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1860" y="1178" width="860" height="76" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="16-t+20~60-分钟后续安排流" name="16 T+20~60 分钟后续安排流"><mxGraphModel dx="2800" dy="1850" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2800" pageHeight="1850" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="2" value="16 T+20~60 分钟后续安排流" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=27;fontColor=#0f172a;fontStyle=1;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="40" y="18" width="1460" height="42" as="geometry"/></mxCell><mxCell id="3" value="安全和外联稳定后，系统开始保护旅行体验：重排行程、住宿和餐饮。" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;fontSize=12;fontColor=#475569;fontStyle=0;align=left;verticalAlign=middle;" parent="1" vertex="1"><mxGeometry x="42" y="60" width="1620" height="26" as="geometry"/></mxCell><mxCell id="5" value="颜色语义&lt;br&gt;绿色=当前已有&lt;br&gt;黄色=stub/审批/半成品&lt;br&gt;橙色=目标态/OEM/外部连接器&lt;br&gt;蓝色=数据对象/状态/控制信息&lt;br&gt;红色=风险/失败回退/容易误解的地方" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=0;fontSize=12;strokeColor=#cbd5e1;fillColor=#f8fafc;fontColor=#475569;align=left;verticalAlign=top;" parent="1" vertex="1"><mxGeometry x="1520" y="18" width="300" height="118" as="geometry"/></mxCell><mxCell id="6" value="后续安排输入
